<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="neTiPx.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:converters="using:neTiPx.Converters"
    xmlns:local="using:neTiPx"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="AppBackgroundColor">#F3F3F3</Color>
                    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
                    <Color x:Key="CardBorderColor">#E6E6E6</Color>
                    <Color x:Key="AppTextColor">#1A1A1A</Color>
                    <Color x:Key="AppTextSecondaryColor">#5A5A5A</Color>
                    <SolidColorBrush x:Key="NavigationViewItemForeground" Color="#1A1A1A" />
                    <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver" Color="#1A1A1A" />
                    <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="#1A1A1A" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="AppBackgroundColor">#202020</Color>
                    <Color x:Key="CardBackgroundColor">#1E1E1E</Color>
                    <Color x:Key="CardBorderColor">#2C2C2C</Color>
                    <Color x:Key="AppTextColor">#FFFFFF</Color>
                    <Color x:Key="AppTextSecondaryColor">#B3B3B3</Color>
                    <SolidColorBrush x:Key="NavigationViewItemForeground" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="#FFFFFF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{ThemeResource AppBackgroundColor}" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="{ThemeResource CardBackgroundColor}" />
            <SolidColorBrush x:Key="CardBorderBrush" Color="{ThemeResource CardBorderColor}" />
            <SolidColorBrush x:Key="AppTextBrush" Color="{ThemeResource AppTextColor}" />
            <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="{ThemeResource AppTextSecondaryColor}" />

            <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
            <Thickness x:Key="CardPadding">16</Thickness>
            <Thickness x:Key="SectionSpacing">0,0,0,16</Thickness>

            <Style x:Key="CardBorder" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
                <Setter Property="Padding" Value="{StaticResource CardPadding}" />
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
            </Style>

            <Style x:Key="SectionTitle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="PrimaryAction" TargetType="Button">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16,10" />
            </Style>

            <converters:GatewayStatusToBrushConverter x:Key="GatewayStatusToBrushConverter" />
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <converters:StringFormatConverter x:Key="StringFormatConverter" />
            <converters:StringToModeConverter x:Key="StringToModeConverter" />
            <converters:RouteModeToBrushConverter x:Key="RouteModeToBrushConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
