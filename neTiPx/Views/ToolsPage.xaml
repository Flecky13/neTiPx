<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Name="ToolsPageRoot"
    x:Class="neTiPx.Views.ToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:neTiPx.ViewModels"
    mc:Ignorable="d">
    <Page.DataContext>
        <viewModels:ToolsViewModel />
    </Page.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header mit Image -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="24" Margin="24,24,24,0">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="8">
                    <TextBlock Text="Tools" Style="{StaticResource SectionTitle}" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="Netzwerk-Utilities und Diagnose-Tools" />
                </StackPanel>
                <Image
                    Grid.Column="1"
                    Source="ms-appx:///Assets/toolicon.png"
                    Width="120"
                    Height="120"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- Einklappbares Menü mit Unterseiten -->
        <NavigationView
            x:Name="ToolsNavView"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="200"
            CompactPaneLength="48"
            IsPaneToggleButtonVisible="True"
            Margin="24,16,24,24"
            SelectionChanged="ToolsNavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="PING" Tag="Ping">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE909;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="WLAN" Tag="Wlan">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE701;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Platzhalter" Tag="Placeholder">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B8;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Visibility>Collapsed</NavigationViewItem.Visibility>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.Content>
                <ScrollViewer>
                    <Grid>
                        <!-- PING Unterseite -->
                        <StackPanel x:Name="PingPanel" Spacing="16" Padding="24" Visibility="Collapsed">
                            <TextBlock Text="PING Tool" Style="{StaticResource SectionTitle}" FontSize="20" FontWeight="SemiBold" />

                            <!-- Konfiguration -->
                            <Border Style="{StaticResource CardBorder}" Padding="16">
                                <StackPanel Spacing="12">
                                    <!-- Header mit Konfiguration und Checkbox -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                        <TextBlock Text="Konfiguration" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock Text="im Hintergrund weiter aktiv" VerticalAlignment="Center" />
                                            <CheckBox x:Name="BackgroundActiveCheckBox" Click="BackgroundActiveCheckBox_Click" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,120,Auto" ColumnSpacing="8">
                                        <TextBox
                                            x:Name="NewPingTargetTextBox"
                                            Grid.Column="0"
                                            Header="Zieladresse"
                                            PlaceholderText="IP-Adresse oder Hostname (z.B. 8.8.8.8, google.com)"
                                            VerticalAlignment="Center" />
                                        <NumberBox
                                            x:Name="PingIntervalNumberBox"
                                            Grid.Column="1"
                                            Header="Intervall (Sek.)"
                                            Value="5"
                                            Minimum="1"
                                            Maximum="60"
                                            SpinButtonPlacementMode="Compact"
                                            VerticalAlignment="Center" />
                                        <Button
                                            Grid.Column="2"
                                            Content="Hinzufügen"
                                            Click="AddPingTarget_Click"
                                            Style="{StaticResource AccentButtonStyle}"
                                            VerticalAlignment="Bottom" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Ping-Ziele Liste -->
                            <Border Style="{StaticResource CardBorder}" Padding="16">
                                <StackPanel Spacing="8">
                                    <!-- Header-Zeile im selben Layout wie Datenzeilen -->
                                    <Border
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12">
                                        <Grid ColumnDefinitions="*,80,84,20,84,20,Auto,Auto,44" ColumnSpacing="8">
                                            <TextBlock Text="Adresse" FontWeight="SemiBold" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                            <TextBlock Text="Intervall" FontWeight="SemiBold" Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                            <TextBlock Text="IPv4" FontWeight="SemiBold" Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                            <TextBlock Text="" Grid.Column="3" />
                                            <TextBlock Text="IPv6" FontWeight="SemiBold" Grid.Column="4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                            <TextBlock Text="" Grid.Column="5" />
                                            <TextBlock Text="Löschen" FontWeight="SemiBold" Grid.Column="6" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            <TextBlock Text="Log" FontWeight="SemiBold" Grid.Column="7" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            <TextBlock Text="Aktiv" FontWeight="SemiBold" Grid.Column="8" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <ItemsControl x:Name="PingTargetsItemsControl" ItemsSource="{Binding PingTargets, ElementName=ToolsPageRoot}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="12"
                                                    Margin="0,0,0,8">
                                                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,80,84,20,84,20,Auto,Auto,44" ColumnSpacing="8" RowSpacing="8">
                                                        <!-- Zeile 1: Aktuelle Daten -->

                                                        <!-- Adresse/IP -->
                                                        <TextBox
                                                            Grid.Row="0"
                                                            Grid.Column="0"
                                                            Text="{Binding Target, Mode=TwoWay}"
                                                            Tag="{Binding}"
                                                            LostFocus="PingTargetTextBox_LostFocus"
                                                            VerticalAlignment="Center" />

                                                        <!-- Intervall pro Ziel -->
                                                        <NumberBox
                                                            Grid.Row="0"
                                                            Grid.Column="1"
                                                            Value="{Binding IntervalSeconds, Mode=TwoWay}"
                                                            Minimum="1"
                                                            Maximum="3600"
                                                            SmallChange="1"
                                                            SpinButtonPlacementMode="Compact"
                                                            Tag="{Binding}"
                                                            ValueChanged="PingIntervalNumberBox_ValueChanged"
                                                            MinWidth="80"
                                                            MaxWidth="80"
                                                            VerticalAlignment="Center" />

                                                        <!-- Antwortzeit IPv4 -->
                                                        <TextBox
                                                            Grid.Row="0"
                                                            Grid.Column="2"
                                                            Text="{Binding ResponseTimeIpv4, Mode=OneWay}"
                                                            IsReadOnly="True"
                                                            PlaceholderText="-- ms"
                                                            MinWidth="84"
                                                            MaxWidth="84"
                                                            VerticalAlignment="Center" />

                                                        <!-- Ampel IPv4 -->
                                                        <Ellipse
                                                            Grid.Row="0"
                                                            Grid.Column="3"
                                                            Width="12"
                                                            Height="12"
                                                            Fill="{Binding StatusColorIpv4}"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            ToolTipService.ToolTip="IPv4 Status" />

                                                        <!-- Antwortzeit IPv6 -->
                                                        <TextBox
                                                            Grid.Row="0"
                                                            Grid.Column="4"
                                                            Text="{Binding ResponseTimeIpv6, Mode=OneWay}"
                                                            IsReadOnly="True"
                                                            PlaceholderText="-- ms"
                                                            MinWidth="84"
                                                            MaxWidth="84"
                                                            VerticalAlignment="Center" />

                                                        <!-- Ampel IPv6 -->
                                                        <Ellipse
                                                            Grid.Row="0"
                                                            Grid.Column="5"
                                                            Width="12"
                                                            Height="12"
                                                            Fill="{Binding StatusColorIpv6}"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            ToolTipService.ToolTip="IPv6 Status" />

                                                        <!-- Löschen Button -->
                                                        <Button
                                                            Grid.Row="0"
                                                            Grid.Column="6"
                                                            Click="DeletePingTarget_Click"
                                                            Tag="{Binding}"
                                                            ToolTipService.ToolTip="Ziel löschen"
                                                            VerticalAlignment="Center"
                                                            Padding="8"
                                                            MinWidth="0">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="16" />
                                                        </Button>

                                                        <Button
                                                            Grid.Row="0"
                                                            Grid.Column="7"
                                                            Click="OpenPingLogButton_Click"
                                                            Tag="{Binding}"
                                                            ToolTipService.ToolTip="Log-Datei öffnen"
                                                            VerticalAlignment="Center"
                                                            Padding="8"
                                                            MinWidth="0">
                                                            <FontIcon Glyph="&#xE8A5;" FontSize="16" />
                                                        </Button>

                                                        <CheckBox
                                                            Grid.Row="0"
                                                            Grid.Column="8"
                                                            IsChecked="{Binding IsPingEnabled, Mode=TwoWay}"
                                                            Tag="{Binding}"
                                                            Click="PingEnabledCheckBox_Click"
                                                            ToolTipService.ToolTip="Ping aktivieren/deaktivieren"
                                                            MinWidth="32"
                                                            MinHeight="32"
                                                            Padding="0"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center">
                                                            <CheckBox.Resources>
                                                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUnchecked" Color="#7A7A7A" />
                                                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillUnchecked" Color="Transparent" />
                                                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeChecked" Color="#0F6CBD" />
                                                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked" Color="#0F6CBD" />
                                                                <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundChecked" Color="#FFFFFF" />
                                                            </CheckBox.Resources>
                                                        </CheckBox>

                                                        <!-- Zeile 2: Statistiken -->

                                                        <!-- Statistiken gesamt wenn beide sichtbar, sonst nur eine -->
                                                        <StackPanel
                                                            Grid.Row="1"
                                                            Grid.Column="0"
                                                            Grid.ColumnSpan="9"
                                                            Orientation="Horizontal"
                                                            Spacing="24"
                                                            Margin="8,0,0,0">
                                                            <TextBlock
                                                                Text="{Binding StatisticsIpv4}"
                                                                FontSize="13"
                                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                VerticalAlignment="Center"
                                                                Visibility="{Binding ShowIPv4}" />
                                                            <TextBlock
                                                                Text="{Binding StatisticsIpv6}"
                                                                FontSize="13"
                                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                VerticalAlignment="Center"
                                                                Visibility="{Binding ShowIPv6}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- WLAN Unterseite -->
                        <StackPanel x:Name="WlanPanel" Spacing="16" Padding="24" Visibility="Collapsed">
                            <TextBlock Text="WLAN Scanner" Style="{StaticResource SectionTitle}" FontSize="20" FontWeight="SemiBold" />

                            <!-- WLAN Layout: Oben volle Breite, darunter zwei Spalten -->
                            <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,*" RowSpacing="16" ColumnSpacing="16">

                                <!-- Oben: Volle Breite -->
                                <Border
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Style="{StaticResource CardBorder}"
                                    Padding="16">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="WLAN-Netzwerke scannen" FontWeight="SemiBold" />
                                        <Button Content="Scan starten" Command="{Binding ScanWifiCommand}" Style="{StaticResource AccentButtonStyle}" />
                                    </StackPanel>
                                </Border>

                                <!-- Unten links: Netzwerk-Liste -->
                                <Border
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Style="{StaticResource CardBorder}"
                                    Padding="16">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Verfügbare Netzwerke" FontWeight="SemiBold" />
                                        <ListBox x:Name="WifiNetworksListBox" ItemsSource="{Binding WifiNetworks}" MinHeight="200" SelectionChanged="WifiNetworksListBox_SelectionChanged" />
                                    </StackPanel>
                                </Border>

                                <!-- Unten rechts: Details/Info -->
                                <Border
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource CardBorder}"
                                    Padding="16">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Netzwerk-Details" FontWeight="SemiBold" />
                                        <TextBlock x:Name="WifiDetailsTextBlock" Text="Wählen Sie ein Netzwerk aus..." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </StackPanel>

                        <!-- Platzhalter Unterseite -->
                        <StackPanel x:Name="PlaceholderPanel" Spacing="16" Padding="24" Visibility="Collapsed">
                            <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" FontSize="20" FontWeight="SemiBold" />
                            <!-- Hier kommt später weiterer Inhalt -->
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </NavigationView.Content>
        </NavigationView>
    </Grid>
</Page>
