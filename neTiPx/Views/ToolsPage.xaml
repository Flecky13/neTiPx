<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="neTiPx.Views.ToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:neTiPx.ViewModels"
    mc:Ignorable="d">
    <Page.DataContext>
        <viewModels:ToolsViewModel />
    </Page.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header mit Image -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="24" Margin="24,24,24,0">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="8">
                    <TextBlock Text="Tools" Style="{StaticResource SectionTitle}" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="Netzwerk-Utilities und Diagnose-Tools" />
                </StackPanel>
                <Image
                    Grid.Column="1"
                    Source="ms-appx:///Assets/toolicon.png"
                    Width="120"
                    Height="120"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- Einklappbares Menü mit Unterseiten -->
        <NavigationView
            x:Name="ToolsNavView"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="200"
            CompactPaneLength="48"
            IsPaneToggleButtonVisible="True"
            Margin="24,16,24,24"
            SelectionChanged="ToolsNavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="PING" Tag="Ping">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE909;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="WLAN" Tag="Wlan">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE701;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Platzhalter" Tag="Placeholder">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B8;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.Content>
                <ScrollViewer>
                    <Grid>
                        <!-- PING Unterseite -->
                        <StackPanel x:Name="PingPanel" Spacing="16" Padding="24" Visibility="Collapsed">
                            <TextBlock Text="PING Tool" Style="{StaticResource SectionTitle}" FontSize="20" FontWeight="SemiBold" />

                            <!-- Konfiguration -->
                            <Border Style="{StaticResource CardBorder}" Padding="16">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Konfiguration" FontWeight="SemiBold" />

                                    <Grid ColumnDefinitions="*,120,Auto" ColumnSpacing="8">
                                        <TextBox
                                            x:Name="NewPingTargetTextBox"
                                            Grid.Column="0"
                                            Header="Zieladresse"
                                            PlaceholderText="IP-Adresse oder Hostname (z.B. 8.8.8.8, google.com)"
                                            VerticalAlignment="Center" />
                                        <NumberBox
                                            x:Name="PingIntervalNumberBox"
                                            Grid.Column="1"
                                            Header="Sekunden"
                                            Value="5"
                                            Minimum="1"
                                            Maximum="60"
                                            SpinButtonPlacementMode="Compact"
                                            VerticalAlignment="Center" />
                                        <Button
                                            Grid.Column="2"
                                            Content="Hinzufügen"
                                            Click="AddPingTarget_Click"
                                            Style="{StaticResource AccentButtonStyle}"
                                            VerticalAlignment="Bottom" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Ping-Ziele Liste -->
                            <Border Style="{StaticResource CardBorder}" Padding="16">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Ping-Ziele" FontWeight="SemiBold" />

                                    <ItemsControl x:Name="PingTargetsItemsControl" ItemsSource="{Binding PingTargets}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="12"
                                                    Margin="0,0,0,8">
                                                    <Grid ColumnDefinitions="*,120,40,Auto" ColumnSpacing="12">
                                                        <!-- Adresse/IP -->
                                                        <TextBox
                                                            Grid.Column="0"
                                                            Text="{Binding Target, Mode=OneWay}"
                                                            IsReadOnly="True"
                                                            VerticalAlignment="Center" />

                                                        <!-- Antwortzeit -->
                                                        <TextBox
                                                            Grid.Column="1"
                                                            Text="{Binding ResponseTime, Mode=OneWay}"
                                                            IsReadOnly="True"
                                                            PlaceholderText="-- ms"
                                                            VerticalAlignment="Center" />

                                                        <!-- Ampel (Qualität) -->
                                                        <Ellipse
                                                            Grid.Column="2"
                                                            Width="24"
                                                            Height="24"
                                                            Fill="{Binding StatusColor}"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center" />

                                                        <!-- Löschen Button -->
                                                        <Button
                                                            Grid.Column="3"
                                                            Click="DeletePingTarget_Click"
                                                            Tag="{Binding}"
                                                            ToolTipService.ToolTip="Ziel löschen"
                                                            VerticalAlignment="Center"
                                                            Padding="8"
                                                            MinWidth="0">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="16" />
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- WLAN Unterseite -->
                        <StackPanel x:Name="WlanPanel" Spacing="16" Padding="24" Visibility="Collapsed">
                            <TextBlock Text="WLAN Scanner" Style="{StaticResource SectionTitle}" FontSize="20" FontWeight="SemiBold" />
                            <!-- Hier kommt später der WLAN-Inhalt -->
                        </StackPanel>

                        <!-- Platzhalter Unterseite -->
                        <StackPanel x:Name="PlaceholderPanel" Spacing="16" Padding="24" Visibility="Collapsed">
                            <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" FontSize="20" FontWeight="SemiBold" />
                            <!-- Hier kommt später weiterer Inhalt -->
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </NavigationView.Content>
        </NavigationView>
    </Grid>
</Page>
