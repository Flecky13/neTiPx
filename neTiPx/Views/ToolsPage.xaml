<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Name="ToolsPageRoot"
    x:Class="neTiPx.Views.ToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:neTiPx.ViewModels"
    mc:Ignorable="d">
    <Page.DataContext>
        <viewModels:ToolsViewModel />
    </Page.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header mit Image -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="24" Margin="24,24,24,0">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="8">
                    <TextBlock Text="Tools" Style="{StaticResource SectionTitle}" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="Netzwerk-Utilities und Diagnose-Tools" />
                </StackPanel>
                <Image
                    Grid.Column="1"
                    Source="ms-appx:///Assets/toolicon.png"
                    Width="120"
                    Height="120"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- Einklappbares Menü mit Unterseiten -->
        <NavigationView
            x:Name="ToolsNavView"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="200"
            CompactPaneLength="48"
            IsPaneToggleButtonVisible="True"
            Margin="24,16,24,24"
            SelectionChanged="ToolsNavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="PING" Tag="Ping">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE909;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="WLAN" Tag="Wlan">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE701;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Netzwerk-Rechner" Tag="NetworkCalculator">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.Content>
                <ScrollViewer>
                    <Grid>
                        <!-- PING Unterseite -->
                        <StackPanel x:Name="PingPanel" Spacing="16" Padding="24" Visibility="Collapsed">
                            <TextBlock Text="PING Tool" Style="{StaticResource SectionTitle}" FontSize="20" FontWeight="SemiBold" />

                            <!-- Konfiguration -->
                            <Border Style="{StaticResource CardBorder}" Padding="16">
                                <StackPanel Spacing="12">
                                    <!-- Header mit Konfiguration und Checkbox -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                        <TextBlock Text="Konfiguration" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock Text="im Hintergrund weiter aktiv" VerticalAlignment="Center" />
                                            <CheckBox x:Name="BackgroundActiveCheckBox" Click="BackgroundActiveCheckBox_Click" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,120,Auto" ColumnSpacing="8">
                                        <TextBox
                                            x:Name="NewPingTargetTextBox"
                                            Grid.Column="0"
                                            Header="Zieladresse"
                                            PlaceholderText="IP-Adresse oder Hostname (z.B. 8.8.8.8, google.com)"
                                            VerticalAlignment="Center" />
                                        <NumberBox
                                            x:Name="PingIntervalNumberBox"
                                            Grid.Column="1"
                                            Header="Intervall (Sek.)"
                                            Value="5"
                                            Minimum="1"
                                            Maximum="60"
                                            SpinButtonPlacementMode="Compact"
                                            VerticalAlignment="Center" />
                                        <Button
                                            Grid.Column="2"
                                            Content="Hinzufügen"
                                            Click="AddPingTarget_Click"
                                            Style="{StaticResource AccentButtonStyle}"
                                            VerticalAlignment="Bottom" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Ping-Ziele Liste -->
                            <Border Style="{StaticResource CardBorder}" Padding="16">
                                <StackPanel Spacing="8">
                                    <!-- Header-Zeile im selben Layout wie Datenzeilen -->
                                    <Border
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12">
                                        <Grid ColumnDefinitions="*,80,84,20,84,20,Auto,Auto,44" ColumnSpacing="8">
                                            <TextBlock Text="Adresse" FontWeight="SemiBold" Grid.Column="0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                            <TextBlock Text="Intervall" FontWeight="SemiBold" Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                            <TextBlock Text="IPv4" FontWeight="SemiBold" Grid.Column="2" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                            <TextBlock Text="" Grid.Column="3" />
                                            <TextBlock Text="IPv6" FontWeight="SemiBold" Grid.Column="4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                            <TextBlock Text="" Grid.Column="5" />
                                            <TextBlock Text="Löschen" FontWeight="SemiBold" Grid.Column="6" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            <TextBlock Text="Log" FontWeight="SemiBold" Grid.Column="7" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            <TextBlock Text="Aktiv" FontWeight="SemiBold" Grid.Column="8" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <ItemsControl x:Name="PingTargetsItemsControl" ItemsSource="{Binding PingTargets, ElementName=ToolsPageRoot}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="12"
                                                    Margin="0,0,0,8">
                                                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,80,84,20,84,20,Auto,Auto,44" ColumnSpacing="8" RowSpacing="8">
                                                        <!-- Zeile 1: Aktuelle Daten -->

                                                        <!-- Adresse/IP -->
                                                        <TextBox
                                                            Grid.Row="0"
                                                            Grid.Column="0"
                                                            Text="{Binding Target, Mode=TwoWay}"
                                                            Tag="{Binding}"
                                                            LostFocus="PingTargetTextBox_LostFocus"
                                                            VerticalAlignment="Center" />

                                                        <!-- Intervall pro Ziel -->
                                                        <NumberBox
                                                            Grid.Row="0"
                                                            Grid.Column="1"
                                                            Value="{Binding IntervalSeconds, Mode=TwoWay}"
                                                            Minimum="1"
                                                            Maximum="3600"
                                                            SmallChange="1"
                                                            SpinButtonPlacementMode="Compact"
                                                            Tag="{Binding}"
                                                            ValueChanged="PingIntervalNumberBox_ValueChanged"
                                                            MinWidth="80"
                                                            MaxWidth="80"
                                                            VerticalAlignment="Center" />

                                                        <!-- Antwortzeit IPv4 -->
                                                        <TextBox
                                                            Grid.Row="0"
                                                            Grid.Column="2"
                                                            Text="{Binding ResponseTimeIpv4, Mode=OneWay}"
                                                            IsReadOnly="True"
                                                            PlaceholderText="-- ms"
                                                            MinWidth="84"
                                                            MaxWidth="84"
                                                            VerticalAlignment="Center" />

                                                        <!-- Ampel IPv4 -->
                                                        <Ellipse
                                                            Grid.Row="0"
                                                            Grid.Column="3"
                                                            Width="12"
                                                            Height="12"
                                                            Fill="{Binding StatusColorIpv4}"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            ToolTipService.ToolTip="IPv4 Status" />

                                                        <!-- Antwortzeit IPv6 -->
                                                        <TextBox
                                                            Grid.Row="0"
                                                            Grid.Column="4"
                                                            Text="{Binding ResponseTimeIpv6, Mode=OneWay}"
                                                            IsReadOnly="True"
                                                            PlaceholderText="-- ms"
                                                            MinWidth="84"
                                                            MaxWidth="84"
                                                            VerticalAlignment="Center" />

                                                        <!-- Ampel IPv6 -->
                                                        <Ellipse
                                                            Grid.Row="0"
                                                            Grid.Column="5"
                                                            Width="12"
                                                            Height="12"
                                                            Fill="{Binding StatusColorIpv6}"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            ToolTipService.ToolTip="IPv6 Status" />

                                                        <!-- Löschen Button -->
                                                        <Button
                                                            Grid.Row="0"
                                                            Grid.Column="6"
                                                            Click="DeletePingTarget_Click"
                                                            Tag="{Binding}"
                                                            ToolTipService.ToolTip="Ziel löschen"
                                                            VerticalAlignment="Center"
                                                            Padding="8"
                                                            MinWidth="0">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="16" />
                                                        </Button>

                                                        <Button
                                                            Grid.Row="0"
                                                            Grid.Column="7"
                                                            Click="OpenPingLogButton_Click"
                                                            Tag="{Binding}"
                                                            ToolTipService.ToolTip="Log-Datei öffnen"
                                                            VerticalAlignment="Center"
                                                            Padding="8"
                                                            MinWidth="0">
                                                            <FontIcon Glyph="&#xE8A5;" FontSize="16" />
                                                        </Button>

                                                        <CheckBox
                                                            Grid.Row="0"
                                                            Grid.Column="8"
                                                            IsChecked="{Binding IsPingEnabled, Mode=TwoWay}"
                                                            Tag="{Binding}"
                                                            Click="PingEnabledCheckBox_Click"
                                                            ToolTipService.ToolTip="Ping aktivieren/deaktivieren"
                                                            MinWidth="32"
                                                            MinHeight="32"
                                                            Padding="0"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center">
                                                            <CheckBox.Resources>
                                                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUnchecked" Color="#7A7A7A" />
                                                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillUnchecked" Color="Transparent" />
                                                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeChecked" Color="#0F6CBD" />
                                                                <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked" Color="#0F6CBD" />
                                                                <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundChecked" Color="#FFFFFF" />
                                                            </CheckBox.Resources>
                                                        </CheckBox>

                                                        <!-- Zeile 2: Statistiken -->

                                                        <!-- Statistiken gesamt wenn beide sichtbar, sonst nur eine -->
                                                        <StackPanel
                                                            Grid.Row="1"
                                                            Grid.Column="0"
                                                            Grid.ColumnSpan="9"
                                                            Orientation="Horizontal"
                                                            Spacing="24"
                                                            Margin="8,0,0,0">
                                                            <TextBlock
                                                                Text="{Binding StatisticsIpv4}"
                                                                FontSize="13"
                                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                VerticalAlignment="Center"
                                                                Visibility="{Binding ShowIPv4}" />
                                                            <TextBlock
                                                                Text="{Binding StatisticsIpv6}"
                                                                FontSize="13"
                                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                VerticalAlignment="Center"
                                                                Visibility="{Binding ShowIPv6}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- WLAN Unterseite -->
                        <StackPanel x:Name="WlanPanel" Spacing="16" Padding="24" Visibility="Collapsed">
                            <TextBlock Text="WLAN Scanner" Style="{StaticResource SectionTitle}" FontSize="20" FontWeight="SemiBold" />

                            <!-- WLAN Layout: Oben Scan-Button, Mitte Netzwerk-Liste, unten Details -->
                            <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*" RowSpacing="16">

                                <!-- Oben: Volle Breite Scan-Button -->
                                <Border
                                    Grid.Row="0"
                                    Style="{StaticResource CardBorder}"
                                    Padding="16">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                        <TextBlock Text="WLAN-Netzwerke scannen" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="Scan starten" Command="{Binding ScanWifiCommand}" Style="{StaticResource AccentButtonStyle}" />
                                    </Grid>
                                </Border>

                                <!-- Mitte: Netzwerk-Liste -->
                                <Border
                                    Grid.Row="1"
                                    Style="{StaticResource CardBorder}"
                                    Padding="16">
                                    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">
                                        <!-- Tabellen-Header -->
                                        <Border Grid.Row="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="2,4">
                                            <Grid ColumnDefinitions="50,200,120,60,120" ColumnSpacing="4">
                                                <Button x:Name="WifiHeaderStrength" Grid.Column="0" Content="📶" Click="WifiHeader_Click" Tag="strength" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" Padding="0" MinHeight="0" MinWidth="0" />
                                                <Button x:Name="WifiHeaderSsid" Grid.Column="1" Content="SSID" Click="WifiHeader_Click" Tag="ssid" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Left" Padding="0" MinHeight="0" MinWidth="0" />
                                                <Button x:Name="WifiHeaderSignal" Grid.Column="2" Content="Signal" Click="WifiHeader_Click" Tag="signal" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" Padding="0" MinHeight="0" MinWidth="0" />
                                                <Button x:Name="WifiHeaderBand" Grid.Column="3" Content="Band" Click="WifiHeader_Click" Tag="band" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" Padding="0" MinHeight="0" MinWidth="0" />
                                                <Button x:Name="WifiHeaderBssid" Grid.Column="4" Content="BSSID" Click="WifiHeader_Click" Tag="bssid" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Right" Padding="0" MinHeight="0" MinWidth="0" />
                                            </Grid>
                                        </Border>

                                        <ListBox Grid.Row="1" x:Name="WifiNetworksListBox" ItemsSource="{Binding WifiNetworks}" SelectionChanged="WifiNetworksListBox_SelectionChanged">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnDefinitions="50,200,120,60,120" ColumnSpacing="4" Padding="2,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                                        <TextBlock Grid.Column="0" Text="{Binding SignalSymbol}" VerticalAlignment="Center" FontSize="12" TextAlignment="Center" />
                                                        <TextBlock Grid.Column="1" Text="{Binding SSID}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12" />
                                                        <TextBlock Grid.Column="2" Text="{Binding SignalStrengthDisplay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextAlignment="Center" />
                                                        <TextBlock Grid.Column="3" Text="{Binding Band}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextAlignment="Center" />
                                                        <TextBlock Grid.Column="4" Text="{Binding BSSID}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextAlignment="Right" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <!-- Unten: Details/Info -->
                                <Border
                                    Grid.Row="2"
                                    Style="{StaticResource CardBorder}"
                                    Padding="16">
                                    <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                                        <TextBlock Grid.Row="0" Text="Netzwerk-Details" FontWeight="SemiBold" />
                                        <Grid Grid.Row="1" x:Name="WifiDetailsGrid" ColumnDefinitions="*,*,*" ColumnSpacing="24" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                            <!-- Spalte 1: Signal -->
                                            <TextBlock Grid.Column="0" Grid.Row="0" FontWeight="SemiBold" Text="Signal" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                            <TextBlock Grid.Column="0" Grid.Row="1" x:Name="WifiDetailSignalStrength" Text="Stärke: --" FontSize="12" />
                                            <TextBlock Grid.Column="0" Grid.Row="2" x:Name="WifiDetailQuality" Text="Qualität: --" FontSize="12" />
                                            <TextBlock Grid.Column="0" Grid.Row="3" x:Name="WifiDetailRssi" Text="RSSI: -- dBm" FontSize="12" />

                                            <!-- Spalte 2: Frequenz -->
                                            <TextBlock Grid.Column="1" Grid.Row="0" FontWeight="SemiBold" Text="Frequenz" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                            <TextBlock Grid.Column="1" Grid.Row="1" x:Name="WifiDetailBand" Text="Band: --" FontSize="12" />
                                            <TextBlock Grid.Column="1" Grid.Row="2" x:Name="WifiDetailChannel" Text="Kanal: --" FontSize="12" />
                                            <TextBlock Grid.Column="1" Grid.Row="3" x:Name="WifiDetailFrequency" Text="Frequenz: --" FontSize="12" />

                                            <!-- Spalte 3: Sicherheit & Standard -->
                                            <TextBlock Grid.Column="2" Grid.Row="0" FontWeight="SemiBold" Text="Sicherheit &amp; Standard" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                            <TextBlock Grid.Column="2" Grid.Row="1" x:Name="WifiDetailSecurity" Text="Verschlüsselung: --" FontSize="12" />
                                            <TextBlock Grid.Column="2" Grid.Row="2" x:Name="WifiDetailPhyType" Text="PHY-Typ: --" FontSize="12" />
                                            <TextBlock Grid.Column="2" Grid.Row="3" x:Name="WifiDetailNetworkType" Text="Netzwerk: --" FontSize="12" />
                                        </Grid>
                                    </Grid>
                                </Border>

                            </Grid>
                        </StackPanel>

                        <!-- Netzwerk-Rechner Unterseite -->
                        <StackPanel x:Name="NetworkCalculatorPanel" Spacing="16" Padding="24" Visibility="Collapsed">
                            <TextBlock Text="Netzwerk-Rechner" Style="{StaticResource SectionTitle}" FontSize="20" FontWeight="SemiBold" />

                            <!-- Eingabefelder -->
                            <Border Style="{StaticResource CardBorder}" Padding="16">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
                                        <StackPanel Grid.Column="0" Spacing="8">
                                            <TextBlock Text="IP-Adresse" FontWeight="SemiBold" />
                                            <TextBox x:Name="NetworkCalcIpAddressTextBox"
                                                     TextChanged="NetworkCalcIpAddressTextBox_TextChanged"
                                                     PlaceholderText="z.B. 192.168.1.0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="8">
                                            <TextBlock Text="Subnetzmaske" FontWeight="SemiBold" />
                                            <TextBox x:Name="NetworkCalcSubnetTextBox"
                                                     TextChanged="NetworkCalcSubnetTextBox_TextChanged"
                                                     PlaceholderText="z.B. 255.255.255.0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="8">
                                            <TextBlock Text="CIDR-Sufix" FontWeight="SemiBold" />
                                            <TextBox x:Name="NetworkCalcCidrTextBox"
                                                     TextChanged="NetworkCalcCidrTextBox_TextChanged"
                                                     PlaceholderText="z.B. 24" />
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Max. Anzahl Hosts" FontWeight="SemiBold" />
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                            <TextBox x:Name="NetworkCalcMaxHostsTextBox"
                                                     Grid.Column="0"
                                                     TextChanged="NetworkCalcMaxHostsTextBox_TextChanged"
                                                     PlaceholderText="z.B. 254" />
                                            <Button Grid.Column="1"
                                                    Content="-"
                                                    Click="NetworkCalcHostsMinusButton_Click"
                                                    ToolTipService.ToolTip="Nächste kleinere gültige Host-Anzahl" />
                                            <Button Grid.Column="2"
                                                    Content="+"
                                                    Click="NetworkCalcHostsPlusButton_Click"
                                                    ToolTipService.ToolTip="Nächste größere gültige Host-Anzahl" />
                                        </Grid>
                                        <TextBlock x:Name="NetworkCalcIpScopeTextBlock"
                                                   Text="IP-Bereich: -"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>

                                </StackPanel>
                            </Border>

                            <!-- Ergebnisse -->
                            <Border Style="{StaticResource CardBorder}" Padding="16" x:Name="NetworkCalcResultsBorder" Visibility="Collapsed">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="Berechnungsergebnisse" FontWeight="SemiBold" FontSize="14" />

                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="12">
                                        <!-- Zeile 1 -->
                                        <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                                            <TextBlock Text="Netzwerkadresse:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                            <TextBlock x:Name="NetworkAddress" Text="-" FontWeight="SemiBold" FontSize="14" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4">
                                            <TextBlock Text="Broadcast-Adresse:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                            <TextBlock x:Name="BroadcastAddress" Text="-" FontWeight="SemiBold" FontSize="14" />
                                        </StackPanel>

                                        <!-- Zeile 2 -->
                                        <StackPanel Grid.Column="0" Grid.Row="1" Spacing="4">
                                            <TextBlock Text="Erste verwertbare IP:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                            <TextBlock x:Name="FirstUsableIp" Text="-" FontWeight="SemiBold" FontSize="14" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="1" Spacing="4">
                                            <TextBlock Text="Letzte verwertbare IP:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                            <TextBlock x:Name="LastUsableIp" Text="-" FontWeight="SemiBold" FontSize="14" />
                                        </StackPanel>

                                        <!-- Zeile 3 -->
                                        <StackPanel Grid.Column="0" Grid.Row="2" Spacing="4">
                                            <TextBlock Text="Subnetzmaske:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                            <TextBlock x:Name="SubnetMask" Text="-" FontWeight="SemiBold" FontSize="14" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="2" Spacing="4">
                                            <TextBlock Text="CIDR-Sufix:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                            <TextBlock x:Name="CidrNotation" Text="-" FontWeight="SemiBold" FontSize="14" />
                                        </StackPanel>

                                        <!-- Zeile 4 -->
                                        <StackPanel Grid.Column="0" Grid.Row="3" Spacing="4">
                                            <TextBlock Text="Anzahl Hosts:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                            <TextBlock x:Name="HostCount" Text="-" FontWeight="SemiBold" FontSize="14" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="3" Spacing="4">
                                            <TextBlock Text="Wildcard-Maske:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                            <TextBlock x:Name="WildcardMask" Text="-" FontWeight="SemiBold" FontSize="14" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Fehlerbehandlung -->
                            <InfoBar x:Name="NetworkCalcErrorBar" Severity="Error" IsOpen="False" IsClosable="True" Margin="0,8,0,0" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </NavigationView.Content>
        </NavigationView>
    </Grid>
</Page>
