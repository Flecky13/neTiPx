<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Name="LogViewerPageRoot"
    x:Class="neTiPx.Views.LogViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:neTiPx.Models"
    mc:Ignorable="d">

    <Grid Padding="0" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="LogViewerTitleText"
                   Text="Log Viewer"
                   Style="{StaticResource SectionTitle}"
                   FontSize="20"
                   FontWeight="SemiBold" />

        <Border Grid.Row="1"
                Style="{StaticResource CardBorder}"
                Padding="16">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12">
                    <Button x:Name="LogViewerOpenButton"
                            Grid.Column="0"
                            Content="Datei öffnen"
                            Click="LogViewerOpenButton_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            MinWidth="140" />

                    <ComboBox x:Name="LogViewerFileComboBox"
                              Grid.Column="1"
                              PlaceholderText="Keine Datei ausgewählt"
                              DisplayMemberPath="DisplayText"
                              SelectionChanged="LogViewerFileComboBox_SelectionChanged"
                              SizeChanged="LogViewerFileComboBox_SizeChanged"
                              HorizontalAlignment="Stretch"
                              Width="Auto"
                              VerticalAlignment="Center" />

                    <Button x:Name="LogViewerReloadButton"
                            Grid.Column="2"
                            Click="LogViewerReloadButton_Click"
                            MinWidth="36"
                            Padding="8,6"
                            IsEnabled="False">
                        <FontIcon Glyph="&#xE72C;" />
                    </Button>
                </Grid>

                <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                      ColumnSpacing="12">
                    <Button x:Name="LogViewerHighlightConfigButton"
                            Grid.Column="0"
                            Content="Highlights"
                            Click="LogViewerHighlightConfigButton_Click"
                            VerticalAlignment="Bottom" />

                    <CheckBox x:Name="LogViewerAutoRefreshCheckBox"
                              Grid.Column="1"
                              Content="Auto aktualisieren"
                              IsChecked="True"
                              Click="LogViewerAutoRefreshCheckBox_Click"
                              VerticalAlignment="Bottom" />

                    <TextBox x:Name="LogViewerFilterTextBox"
                             Grid.Column="2"
                             Header="Filter"
                             PlaceholderText="Text enthalten..."
                             TextChanged="LogViewerFilterTextBox_TextChanged" />

                    <TextBlock x:Name="LogViewerMatchesText"
                               Grid.Column="3"
                               Text="0 / 0"
                               VerticalAlignment="Bottom"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>

            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorder}"
                Padding="0"
                Background="Black">
            <ListView x:Name="LogViewerListView"
                      ItemsSource="{x:Bind Lines, Mode=OneWay}"
                      SelectionMode="None"
                      IsItemClickEnabled="False"
                      Padding="0"
                      Background="Black"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:LogViewerLine">
                        <Border Background="{x:Bind BackgroundBrush, Mode=OneWay}"
                                Padding="3,0"
                                Margin="0">
                            <ItemsControl ItemsSource="{x:Bind Segments, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:LogViewerTextSegment">
                                        <Border Background="{x:Bind BackgroundBrush, Mode=OneWay}">
                                            <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                                                       Foreground="{x:Bind ForegroundBrush, Mode=OneWay}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       LineHeight="13"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="None" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
