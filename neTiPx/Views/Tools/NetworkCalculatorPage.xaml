<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Name="NetworkCalculatorPageRoot"
    x:Class="neTiPx.Views.NetworkCalculatorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="16" Padding="24">
        <!-- Header mit RadioButtons -->
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
            <TextBlock Grid.Column="0" Text="Netzwerk-Rechner" Style="{StaticResource SectionTitle}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <RadioButton x:Name="NetworkCalcIpv4RadioButton" Content="IPv4" IsChecked="True" Checked="NetworkCalcIpVersionRadioButton_Checked" />
                <RadioButton x:Name="NetworkCalcIpv6RadioButton" Content="IPv6" Checked="NetworkCalcIpVersionRadioButton_Checked" />
            </StackPanel>
        </Grid>

        <!-- IPv4 Eingabefelder -->
        <Border x:Name="NetworkCalcIpv4InputBorder" Style="{StaticResource CardBorder}" Padding="16">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="IP-Adresse" FontWeight="SemiBold" />
                        <TextBox x:Name="NetworkCalcIpAddressTextBox"
                                 TextChanged="NetworkCalcIpAddressTextBox_TextChanged"
                                 PlaceholderText="z.B. 192.168.1.0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="Subnetzmaske" FontWeight="SemiBold" />
                        <TextBox x:Name="NetworkCalcSubnetTextBox"
                                 TextChanged="NetworkCalcSubnetTextBox_TextChanged"
                                 PlaceholderText="z.B. 255.255.255.0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="8">
                        <TextBlock Text="CIDR-Sufix" FontWeight="SemiBold" />
                        <TextBox x:Name="NetworkCalcCidrTextBox"
                                 TextChanged="NetworkCalcCidrTextBox_TextChanged"
                                 PlaceholderText="z.B. 24" />
                    </StackPanel>
                </Grid>

                <StackPanel Spacing="8">
                    <TextBlock Text="Max. Anzahl Hosts" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <TextBox x:Name="NetworkCalcMaxHostsTextBox"
                                 Grid.Column="0"
                                 TextChanged="NetworkCalcMaxHostsTextBox_TextChanged"
                                 PlaceholderText="z.B. 254" />
                        <Button Grid.Column="1"
                                Content="-"
                                Click="NetworkCalcHostsMinusButton_Click"
                                ToolTipService.ToolTip="Anzahl hosts reduzieren " />
                        <Button Grid.Column="2"
                                Content="+"
                                Click="NetworkCalcHostsPlusButton_Click"
                                ToolTipService.ToolTip="Anzahl Hosts erhöhen" />
                    </Grid>
                    <TextBlock x:Name="NetworkCalcIpScopeTextBlock"
                               Text="IP-Bereich: -"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- IPv6 Eingabefelder -->
        <Border x:Name="NetworkCalcIpv6InputBorder" Style="{StaticResource CardBorder}" Padding="16" Visibility="Collapsed">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="IPv6-Adresse" FontWeight="SemiBold" />
                        <TextBox x:Name="NetworkCalcIpv6AddressTextBox"
                                 TextChanged="NetworkCalcIpv6AddressTextBox_TextChanged"
                                 PlaceholderText="z.B. 2001:db8::" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="8" MinWidth="150">
                        <TextBlock Text="Präfixlänge" FontWeight="SemiBold" />
                        <TextBox x:Name="NetworkCalcIpv6PrefixTextBox"
                                 TextChanged="NetworkCalcIpv6PrefixTextBox_TextChanged"
                                 PlaceholderText="z.B. 64" />
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="NetworkCalcIpv6ScopeTextBlock"
                           Text="IP-Bereich: -"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- IPv4 Ergebnisse -->
        <Border x:Name="NetworkCalcIpv4ResultsBorder" Style="{StaticResource CardBorder}" Padding="16" Visibility="Collapsed">
            <StackPanel Spacing="12">
                <TextBlock Text="Berechnungsergebnisse" FontWeight="SemiBold" FontSize="14" />

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="12">
                    <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                        <TextBlock Text="Netzwerkadresse:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock x:Name="NetworkAddress" Text="-" FontWeight="SemiBold" FontSize="14" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4">
                        <TextBlock Text="Broadcast-Adresse:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock x:Name="BroadcastAddress" Text="-" FontWeight="SemiBold" FontSize="14" />
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="1" Spacing="4">
                        <TextBlock Text="Erste verwertbare IP:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock x:Name="FirstUsableIp" Text="-" FontWeight="SemiBold" FontSize="14" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="1" Spacing="4">
                        <TextBlock Text="Letzte verwertbare IP:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock x:Name="LastUsableIp" Text="-" FontWeight="SemiBold" FontSize="14" />
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="2" Spacing="4">
                        <TextBlock Text="Subnetzmaske:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock x:Name="SubnetMask" Text="-" FontWeight="SemiBold" FontSize="14" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="2" Spacing="4">
                        <TextBlock Text="CIDR-Sufix:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock x:Name="CidrNotation" Text="-" FontWeight="SemiBold" FontSize="14" />
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="3" Spacing="4">
                        <TextBlock Text="Anzahl Hosts:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock x:Name="HostCount" Text="-" FontWeight="SemiBold" FontSize="14" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="3" Spacing="4">
                        <TextBlock Text="Wildcard-Maske:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock x:Name="WildcardMask" Text="-" FontWeight="SemiBold" FontSize="14" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- IPv6 Ergebnisse -->
        <Border x:Name="NetworkCalcIpv6ResultsBorder" Style="{StaticResource CardBorder}" Padding="16" Visibility="Collapsed">
            <StackPanel Spacing="12">
                <TextBlock Text="Berechnungsergebnisse" FontWeight="SemiBold" FontSize="14" />

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="12">
                    <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                        <TextBlock Text="Netzwerkadresse:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock x:Name="NetworkAddressIpv6" Text="-" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4">
                        <TextBlock Text="Präfixlänge:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock x:Name="PrefixLengthIpv6" Text="-" FontWeight="SemiBold" FontSize="14" />
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="1" Spacing="4">
                        <TextBlock Text="Erste Adresse:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock x:Name="FirstAddressIpv6" Text="-" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="1" Spacing="4">
                        <TextBlock Text="Letzte Adresse:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock x:Name="LastAddressIpv6" Text="-" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Spacing="4">
                        <TextBlock Text="Anzahl Adressen:" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        <TextBlock x:Name="AddressCountIpv6" Text="-" FontWeight="SemiBold" FontSize="14" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Fehlerbehandlung -->
        <InfoBar x:Name="NetworkCalcErrorBar" Severity="Error" IsOpen="False" IsClosable="True" Margin="0,8,0,0" />
    </StackPanel>
</Page>
