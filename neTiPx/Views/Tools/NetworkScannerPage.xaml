<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Name="NetworkScannerPageRoot"
    x:Class="neTiPx.Views.NetworkScannerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="16">
        <TextBlock x:Name="NetworkScanTitleText" Text="Netzwerkscanner" Style="{StaticResource SectionTitle}" FontSize="20" FontWeight="SemiBold" />

        <!-- Scan-Konfiguration -->
        <Border Style="{StaticResource CardBorder}" Padding="16">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock x:Name="NetworkScanRangesLabelText" Text="IP-Bereiche" FontWeight="SemiBold" />
                        <TextBox x:Name="NetworkScanRangesTextBox"
                                 PlaceholderText="z.B. 192.168.1.1-254;192.168.2.10-50" />
                        <TextBlock x:Name="NetworkScanRangesHintText"
                                   Text="Format: 192.168.1.1-254, mehrere Bereiche mit ; trennen"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            x:Name="NetworkScanStartButton"
                            Content="Scan starten"
                            Click="NetworkScanStartButton_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            VerticalAlignment="Bottom"
                            MinWidth="120" />
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock x:Name="NetworkScanStatusTextBlock"
                               Text="Bereit zum Scannen"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <ProgressRing x:Name="NetworkScanProgressRing"
                                  IsActive="False"
                                  Width="20"
                                  Height="20" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Scan-Ergebnisse: Grid mit 2 separaten Bereichen -->
        <Grid ColumnDefinitions="*,250" ColumnSpacing="16" Height="380">
            <!-- Linker Bereich: Geräteliste -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="16">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="NetworkScanFoundDevicesTitleText" Grid.Column="0" Text="Gefundene Geräte" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Grid.Column="1" x:Name="NetworkScanCountTextBlock" Text="0 Geräte" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>

                    <!-- Header-Zeile -->
                    <Border Grid.Row="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="8,4">
                        <Grid ColumnDefinitions="100,120,80" ColumnSpacing="12">
                            <Button x:Name="NetworkScanHeaderIp" Grid.Column="0" Content="IP-Adresse" Click="NetworkScanHeader_Click" Tag="ip" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Left" Padding="0" MinHeight="0" MinWidth="0" />
                            <Button x:Name="NetworkScanHeaderMac" Grid.Column="1" Content="MAC-Adresse" Click="NetworkScanHeader_Click" Tag="mac" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Left" Padding="0" MinHeight="0" MinWidth="0" />
                            <Button x:Name="NetworkScanHeaderPorts" Grid.Column="2" Content="Open Ports" Click="NetworkScanHeader_Click" Tag="ports" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Left" Padding="0" MinHeight="0" MinWidth="0" />
                        </Grid>
                    </Border>

                    <!-- Geräte-Liste mit Scrollbar -->
                    <ListView Grid.Row="2"
                              x:Name="NetworkScanResultsListView"
                              ItemsSource="{x:Bind NetworkDevices, Mode=OneWay}"
                              SelectionMode="Single"
                              SelectionChanged="NetworkScanResultsListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="100,140,30" ColumnSpacing="12" Padding="4,2">
                                    <TextBlock Grid.Column="0" Text="{Binding IpAddress}" FontSize="13" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding MacAddress}" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding OpenPorts.Count}" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Rechter Bereich: Details -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="16">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                    <TextBlock x:Name="NetworkScanDetailsTitleText" Grid.Row="0" Text="Geräte-Details" FontWeight="SemiBold" FontSize="14" />

                    <TextBlock x:Name="NetworkScanDetailsPlaceholderText"
                               Grid.Row="1"
                               Text="Wählen Sie links ein Gerät aus."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Top"
                               TextWrapping="Wrap" />

                    <StackPanel x:Name="NetworkScanDetailsPanel" Grid.Row="1" Spacing="8" Visibility="Collapsed">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="DeviceDetailsIpLabelText" Text="IP-Adresse:" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="DeviceDetailsIpTextBlock" FontSize="13" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock x:Name="DeviceDetailsMacLabelText" Text="MAC-Adresse:" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="DeviceDetailsMacTextBlock" FontSize="13" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock x:Name="DeviceDetailsHostnameLabelText" Text="Hostname:" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="DeviceDetailsHostnameTextBlock" FontSize="13" TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel x:Name="DeviceDetailsPortsPanel" Spacing="4" Visibility="Collapsed">
                            <TextBlock x:Name="DeviceDetailsPortsLabelText" Text="Offene Ports (Doppelklick zum Öffnen):" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ListView x:Name="DeviceDetailsPortsListView"
                                      SelectionMode="Single"
                                      IsItemClickEnabled="False"
                                      DoubleTapped="DeviceDetailsPortsListView_DoubleTapped">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="13" Margin="0,2" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" TextDecorations="Underline" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Fehlerbehandlung -->
        <InfoBar x:Name="NetworkScanErrorBar" Severity="Error" IsOpen="False" IsClosable="True" Margin="0,8,0,0" />
    </StackPanel>
</Page>
