<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="neTiPx.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="24">
            <!-- Header mit Image -->
            <Border Style="{StaticResource CardBorder}" Padding="24">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Einstellungen" Style="{StaticResource SectionTitle}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="Konfiguriere dein Tool nach deinen Wünschen" />
                    </StackPanel>
                    <Image
                        Grid.Column="1"
                        Source="ms-appx:///Assets/toolicon.png"
                        Width="120"
                        Height="120"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- 3x3 Grid für Konfigurationsbereiche -->
            <Grid RowSpacing="16" ColumnSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Oben Links: Farbe -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="0" Grid.Column="0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Farbschema" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Wählen Sie die Akzentfarbe" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                        <ComboBox
                            x:Name="ColorSchemeCombo"
                            HorizontalAlignment="Stretch"
                            DisplayMemberPath="DisplayName"
                            SelectionChanged="ColorSchemeCombo_SelectionChanged" />
                    </StackPanel>
                </Border>

                <!-- Oben Mitte: Adapter Auswahl -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="0" Grid.Column="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Netzwerkadapter" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Wählen Sie die primären und sekundären Adapter" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />

                        <!-- Primärer Adapter -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Primärer Adapter (NIC 1):" FontWeight="SemiBold" FontSize="12" />
                            <ComboBox
                                x:Name="PrimaryAdapterCombo"
                                HorizontalAlignment="Stretch"
                                PlaceholderText="Adapter wählen..."
                                SelectionChanged="PrimaryAdapterCombo_SelectionChanged" />
                        </StackPanel>

                        <!-- Sekundärer Adapter -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Sekundärer Adapter (NIC 2):" FontWeight="SemiBold" FontSize="12" />
                            <ComboBox
                                x:Name="SecondaryAdapterCombo"
                                HorizontalAlignment="Stretch"
                                PlaceholderText="Adapter wählen..."
                                SelectionChanged="SecondaryAdapterCombo_SelectionChanged" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Oben Rechts: Maus Over Info Fenster -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="0" Grid.Column="2">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Maus Over Info Fenster" Style="{StaticResource SectionTitle}" />

                        <!-- Vertikales Layout für die zwei Dropdowns untereinander -->
                        <StackPanel Spacing="8">

                            <!-- Aktiv/Inaktiv Dropdown mit Label -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Anzeige" FontWeight="SemiBold" FontSize="12" />
                                <ComboBox
                                    x:Name="HoverWindowStateCombo"
                                    HorizontalAlignment="Stretch"
                                    SelectionChanged="HoverWindowStateCombo_SelectionChanged"
                                    PlaceholderText="Wählen...">
                                    <ComboBoxItem>Aktiv</ComboBoxItem>
                                    <ComboBoxItem>Inaktiv</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>

                            <!-- Verzögerung Dropdown mit Label -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Verzögert" FontWeight="SemiBold" FontSize="12" />
                                <ComboBox
                                    x:Name="HoverWindowDelayCombo"
                                    HorizontalAlignment="Stretch"
                                    SelectionChanged="HoverWindowDelayCombo_SelectionChanged"
                                    PlaceholderText="Wählen...">
                                    <ComboBoxItem>1 Sek.</ComboBoxItem>
                                    <ComboBoxItem>2 Sek.</ComboBoxItem>
                                    <ComboBoxItem>3 Sek.</ComboBoxItem>
                                    <ComboBoxItem>4 Sek.</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Mitte Links: Verbindungsstatus -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="1" Grid.Column="0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Verbindungsstatus" Style="{StaticResource SectionTitle}" />

                        <!-- Drei Zahlenfelder für Ping-Schwellenwerte -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <!-- Schnell -->
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Schnell" FontWeight="SemiBold" FontSize="12" />
                                <TextBox
                                    x:Name="PingThresholdFastTextBox"
                                    Text="20"
                                    InputScope="Number"
                                    MaxLength="3"
                                    HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <!-- Normal -->
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Normal" FontWeight="SemiBold" FontSize="12" />
                                <TextBox
                                    x:Name="PingThresholdNormalTextBox"
                                    Text="50"
                                    InputScope="Number"
                                    MaxLength="3"
                                    HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <!-- Langsam -->
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Langsam" FontWeight="SemiBold" FontSize="12" />
                                <TextBox
                                    x:Name="PingThresholdSlowTextBox"
                                    Text="100"
                                    InputScope="Number"
                                    MaxLength="3"
                                    HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Grid>

                        <!-- Drei Checkboxen für Gateway/DNS -->
                        <StackPanel Spacing="6">
                            <CheckBox x:Name="CheckGatewayCheckBox" Content="Gateway" IsChecked="True" Checked="CheckGatewayCheckBox_Checked" Unchecked="CheckGatewayCheckBox_Unchecked" />
                            <CheckBox x:Name="CheckDns1CheckBox" Content="DNS 1" IsChecked="True" Checked="CheckDns1CheckBox_Checked" Unchecked="CheckDns1CheckBox_Unchecked" />
                            <CheckBox x:Name="CheckDns2CheckBox" Content="DNS 2" IsChecked="True" Checked="CheckDns2CheckBox_Checked" Unchecked="CheckDns2CheckBox_Unchecked" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Mitte Mitte: Platzhalter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="1" Grid.Column="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Zukünftige Konfiguration" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Mitte Rechts: Platzhalter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="1" Grid.Column="2">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Zukünftige Konfiguration" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Unten Links: Platzhalter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="2" Grid.Column="0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Zukünftige Konfiguration" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Unten Mitte: Platzhalter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="2" Grid.Column="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Zukünftige Konfiguration" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Unten Rechts: Platzhalter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="2" Grid.Column="2">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Zukünftige Konfiguration" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
