<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Name="RootControl"
    x:Class="neTiPx.Views.RouteConfigDialogContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:neTiPx.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:neTiPx.Models"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Background="{ThemeResource AppBackgroundBrush}">
        <StackPanel Spacing="16" Padding="24" MinWidth="680" HorizontalAlignment="Stretch">
            <Border Style="{StaticResource CardBorder}" Padding="24">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="DialogTitleText" Text="Routen konfigurieren" Style="{StaticResource SectionTitle}" FontSize="24" FontWeight="Bold" />
                    <TextBlock x:Name="DialogSubtitleText" Text="Konfiguriere statische IPv4-Routen, die beim Anwenden des Profils zusätzlich gesetzt werden." TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Padding="16">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="SystemSectionTitleText" Text="Ständige Routen im System" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="{x:Bind SystemRoutesStatus, Mode=OneWay}" Foreground="{ThemeResource AppTextSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                        <Button x:Name="ReloadSystemRoutesButton" Grid.Column="1" Click="ReloadSystemRoutes_Click" Style="{StaticResource AccentButtonStyle}" Foreground="{ThemeResource AccentButtonForeground}" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="{Binding Foreground, ElementName=ReloadSystemRoutesButton}" />
                                <TextBlock x:Name="ReloadSystemRoutesButtonText" Text="Neu Einlesen" Foreground="{Binding Foreground, ElementName=ReloadSystemRoutesButton}" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid ColumnDefinitions="140,140,140,50,90" ColumnSpacing="6" Margin="0,4,0,0">
                        <TextBlock x:Name="SystemHeaderDestinationText" Text="Zielnetz" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        <TextBlock x:Name="SystemHeaderSubnetText" Grid.Column="1" Text="Subnetzmaske" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        <TextBlock x:Name="SystemHeaderGatewayText" Grid.Column="2" Text="Gateway" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        <TextBlock x:Name="SystemHeaderMetricText" Grid.Column="3" Text="Metrik" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        <TextBlock x:Name="SystemHeaderActionText" Grid.Column="4" Text="Aktion" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                    </Grid>

                    <ScrollViewer MaxHeight="170" VerticalScrollBarVisibility="Auto">
                        <ItemsRepeater ItemsSource="{x:Bind SystemRoutes, Mode=OneWay}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:RouteEntry">
                                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="2" Margin="0">
                                        <Grid ColumnDefinitions="140,140,140,50,90" ColumnSpacing="6">
                                            <Border
                                                Grid.ColumnSpan="5"
                                                Width="6"
                                                HorizontalAlignment="Left"
                                                CornerRadius="3"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                Visibility="{x:Bind IsProfileMatch, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <TextBlock Text="{x:Bind Destination, Mode=OneWay}" VerticalAlignment="Center" Margin="1,0" Width="120" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind SubnetMask, Mode=OneWay}" VerticalAlignment="Center" Margin="1,0" Width="120" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind Gateway, Mode=OneWay}" VerticalAlignment="Center" Margin="1,0" Width="120" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="3" Text="{x:Bind Metric, Mode=OneWay}" VerticalAlignment="Center" Margin="1,0" Width="40" TextAlignment="Right" />
                                            <Grid Grid.Column="4">
                                                <Button
                                                    Tag="{x:Bind}"
                                                    Click="RemoveSystemRoute_Click"
                                                    ToolTipService.ToolTip="{Binding ElementName=RootControl, Path=DeleteSystemRouteToolTip, Mode=OneWay}"
                                                    VerticalAlignment="Center"
                                                    Padding="8"
                                                    MinWidth="0"
                                                    Visibility="{x:Bind CanDeleteFromSystem, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="16" />
                                                </Button>
                                                <TextBlock
                                                    Text="{Binding ElementName=RootControl, Path=ProfileBadgeText, Mode=OneWay}"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    FontWeight="SemiBold"
                                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                    Visibility="{x:Bind IsProfileMatch, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Padding="16">
                <StackPanel Spacing="12">
                    <Grid>
                        <TextBlock x:Name="ProfileRoutesSectionTitleText" Text="Neue Routen für dieses Profil" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                        <Button x:Name="AddRouteButton" Click="AddRoute_Click" Style="{StaticResource AccentButtonStyle}" Foreground="{ThemeResource AccentButtonForeground}" IsEnabled="{x:Bind CanAddRoute, Mode=OneWay}" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="14" Foreground="{Binding Foreground, ElementName=AddRouteButton}" />
                                <TextBlock x:Name="AddRouteButtonText" Text="Route hinzufügen" Foreground="{Binding Foreground, ElementName=AddRouteButton}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <Grid ColumnDefinitions="140,140,140,50,90" ColumnSpacing="6" Margin="0,4,0,0">
                        <TextBlock x:Name="ProfileHeaderDestinationText" Text="Zielnetz" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        <TextBlock x:Name="ProfileHeaderSubnetText" Grid.Column="1" Text="Subnetzmaske" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        <TextBlock x:Name="ProfileHeaderGatewayText" Grid.Column="2" Text="Gateway" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        <TextBlock x:Name="ProfileHeaderMetricText" Grid.Column="3" Text="Metrik" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        <TextBlock x:Name="ProfileHeaderActionText" Grid.Column="4" Text="Aktion" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                    </Grid>

                    <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                        <ItemsRepeater ItemsSource="{x:Bind Routes, Mode=OneWay}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:RouteEntry">
                                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="2" Margin="0,0,0,1">
                                        <Grid ColumnDefinitions="140,140,140,50,90" ColumnSpacing="6">
                                            <TextBox
                                                Text="{x:Bind Destination, Mode=TwoWay}"
                                                PlaceholderText="{Binding ElementName=RootControl, Path=AddDestinationPlaceholder, Mode=OneWay}"
                                                Margin="1,0"
                                                ToolTipService.ToolTip="{Binding ElementName=RootControl, Path=AddDestinationToolTip, Mode=OneWay}" />
                                            <TextBox
                                                Grid.Column="1"
                                                Text="{x:Bind SubnetMask, Mode=TwoWay}"
                                                PlaceholderText="{Binding ElementName=RootControl, Path=AddSubnetPlaceholder, Mode=OneWay}"
                                                Margin="1,0"
                                                ToolTipService.ToolTip="{Binding ElementName=RootControl, Path=AddSubnetToolTip, Mode=OneWay}" />
                                            <TextBox
                                                Grid.Column="2"
                                                Text="{x:Bind Gateway, Mode=TwoWay}"
                                                PlaceholderText="{Binding ElementName=RootControl, Path=AddGatewayPlaceholder, Mode=OneWay}"
                                                Margin="1,0"
                                                ToolTipService.ToolTip="{Binding ElementName=RootControl, Path=AddGatewayToolTip, Mode=OneWay}" />
                                            <TextBox
                                                Grid.Column="3"
                                                Text="{x:Bind Metric, Mode=TwoWay}"
                                                PlaceholderText="{Binding ElementName=RootControl, Path=AddMetricPlaceholder, Mode=OneWay}"
                                                Margin="1,0"
                                                ToolTipService.ToolTip="{Binding ElementName=RootControl, Path=AddMetricToolTip, Mode=OneWay}" />
                                            <Button
                                                Grid.Column="4"
                                                Tag="{x:Bind}"
                                                Click="RemoveRoute_Click"
                                                ToolTipService.ToolTip="{Binding ElementName=RootControl, Path=RemoveProfileRouteToolTip, Mode=OneWay}"
                                                VerticalAlignment="Center"
                                                Padding="8"
                                                MinWidth="0"
                                                Visibility="{x:Bind ShowDeleteButton, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <FontIcon Glyph="&#xE74D;" FontSize="16" />
                                            </Button>
                                            <Button
                                                Grid.Column="4"
                                                Tag="{x:Bind}"
                                                Click="ApplyRoute_Click"
                                                ToolTipService.ToolTip="{Binding ElementName=RootControl, Path=ApplyProfileRouteToolTip, Mode=OneWay}"
                                                VerticalAlignment="Center"
                                                Padding="8"
                                                MinWidth="0"
                                                Visibility="{x:Bind ShowApplyButton, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <FontIcon Glyph="&#xE73E;" FontSize="16" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
