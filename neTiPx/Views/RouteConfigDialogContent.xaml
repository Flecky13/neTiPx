<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="neTiPx.Views.RouteConfigDialogContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:neTiPx.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:neTiPx.Models"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Background="{ThemeResource AppBackgroundBrush}">
        <StackPanel Spacing="16" Padding="24" MinWidth="680" HorizontalAlignment="Stretch">
            <Border Style="{StaticResource CardBorder}" Padding="24">
                <StackPanel Spacing="8">
                    <TextBlock Text="Routen konfigurieren" Style="{StaticResource SectionTitle}" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="Konfiguriere statische IPv4-Routen, die beim Anwenden des Profils zusätzlich gesetzt werden." TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Padding="16">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Ständige Routen im System" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="{x:Bind SystemRoutesStatus, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                        <Button Grid.Column="1" Click="ReloadSystemRoutes_Click" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                <TextBlock Text="Neu Einlesen" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid ColumnDefinitions="140,140,140,50,90" ColumnSpacing="6" Margin="0,4,0,0">
                        <TextBlock Text="Zielnetz" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="Subnetzmaske" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="2" Text="Gateway" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="3" Text="Metrik" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="4" Text="Aktion" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>

                    <ScrollViewer MaxHeight="170" VerticalScrollBarVisibility="Auto">
                        <ItemsRepeater ItemsSource="{x:Bind SystemRoutes, Mode=OneWay}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:RouteEntry">
                                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="2" Margin="0">
                                        <Grid ColumnDefinitions="140,140,140,50,90" ColumnSpacing="6">
                                            <Border
                                                Grid.ColumnSpan="5"
                                                Width="6"
                                                HorizontalAlignment="Left"
                                                CornerRadius="3"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                Visibility="{x:Bind IsProfileMatch, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <TextBlock Text="{x:Bind Destination, Mode=OneWay}" VerticalAlignment="Center" Margin="1,0" Width="120" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind SubnetMask, Mode=OneWay}" VerticalAlignment="Center" Margin="1,0" Width="120" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind Gateway, Mode=OneWay}" VerticalAlignment="Center" Margin="1,0" Width="120" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="3" Text="{x:Bind Metric, Mode=OneWay}" VerticalAlignment="Center" Margin="1,0" Width="40" TextAlignment="Right" />
                                            <Grid Grid.Column="4">
                                                <Button
                                                    Tag="{x:Bind}"
                                                    Click="RemoveSystemRoute_Click"
                                                    ToolTipService.ToolTip="Route im System löschen"
                                                    HorizontalAlignment="Stretch"
                                                    Padding="6,3"
                                                    Visibility="{x:Bind CanDeleteFromSystem, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                                        <TextBlock Text="Löschen" />
                                                    </StackPanel>
                                                </Button>
                                                <TextBlock
                                                    Text="Profil"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    FontWeight="SemiBold"
                                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                    Visibility="{x:Bind IsProfileMatch, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Padding="16">
                <StackPanel Spacing="12">
                    <Grid>
                        <TextBlock Text="Neue Routen für dieses Profil" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                        <Button Click="AddRoute_Click" Style="{StaticResource AccentButtonStyle}" IsEnabled="{x:Bind CanAddRoute, Mode=OneWay}" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                                <TextBlock Text="Route hinzufügen" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <Grid ColumnDefinitions="140,140,140,50,90" ColumnSpacing="6" Margin="0,4,0,0">
                        <TextBlock Text="Zielnetz" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="Subnetzmaske" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="2" Text="Gateway" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="3" Text="Metrik" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="4" Text="Aktion" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>

                    <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                        <ItemsRepeater ItemsSource="{x:Bind Routes, Mode=OneWay}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:RouteEntry">
                                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="2" Margin="0,0,0,1">
                                        <Grid ColumnDefinitions="140,140,140,50,90" ColumnSpacing="6">
                                            <TextBox
                                                Text="{x:Bind Destination, Mode=TwoWay}"
                                                PlaceholderText="z.B. 10.10.0.0"
                                                Margin="1,0"
                                                ToolTipService.ToolTip="Zielnetzadresse" />
                                            <TextBox
                                                Grid.Column="1"
                                                Text="{x:Bind SubnetMask, Mode=TwoWay}"
                                                PlaceholderText="z.B. 255.255.255.0"
                                                Margin="1,0"
                                                ToolTipService.ToolTip="Subnetzmaske" />
                                            <TextBox
                                                Grid.Column="2"
                                                Text="{x:Bind Gateway, Mode=TwoWay}"
                                                PlaceholderText="z.B. 192.168.1.1"
                                                Margin="1,0"
                                                ToolTipService.ToolTip="Gateway" />
                                            <TextBox
                                                Grid.Column="3"
                                                Text="{x:Bind Metric, Mode=TwoWay}"
                                                PlaceholderText="1"
                                                Margin="1,0"
                                                ToolTipService.ToolTip="Metrik > 0" />
                                            <Button
                                                Grid.Column="4"
                                                Tag="{x:Bind}"
                                                Click="RemoveRoute_Click"
                                                ToolTipService.ToolTip="Route löschen"
                                                HorizontalAlignment="Stretch"
                                                Padding="6,3">
                                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                                    <TextBlock Text="Löschen" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
