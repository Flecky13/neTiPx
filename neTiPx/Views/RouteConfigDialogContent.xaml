<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="neTiPx.Views.RouteConfigDialogContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:neTiPx.Models"
    mc:Ignorable="d">
    <StackPanel Spacing="10" MinWidth="1180" HorizontalAlignment="Stretch">
        <TextBlock Text="Konfiguriere statische IPv4-Routen, die beim Anwenden des Profils gesetzt werden." TextWrapping="Wrap" />

        <Grid ColumnDefinitions="*,*,*,120,110" ColumnSpacing="8" Margin="0,4,0,0">
            <TextBlock Text="Zielnetz" FontWeight="SemiBold" FontSize="12" />
            <TextBlock Grid.Column="1" Text="Subnetzmaske" FontWeight="SemiBold" FontSize="12" />
            <TextBlock Grid.Column="2" Text="Gateway" FontWeight="SemiBold" FontSize="12" />
            <TextBlock Grid.Column="3" Text="Metrik" FontWeight="SemiBold" FontSize="12" />
            <TextBlock Grid.Column="4" Text="Aktion" FontWeight="SemiBold" FontSize="12" />
        </Grid>

        <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
            <ItemsRepeater ItemsSource="{x:Bind Routes, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:RouteEntry">
                        <Grid ColumnDefinitions="*,*,*,120,110" ColumnSpacing="8" Margin="0,0,0,8">
                            <TextBox
                                Text="{x:Bind Destination, Mode=TwoWay}"
                                PlaceholderText="z.B. 10.10.0.0"
                                ToolTipService.ToolTip="Zielnetzadresse" />
                            <TextBox
                                Grid.Column="1"
                                Text="{x:Bind SubnetMask, Mode=TwoWay}"
                                PlaceholderText="z.B. 255.255.255.0"
                                ToolTipService.ToolTip="Subnetzmaske" />
                            <TextBox
                                Grid.Column="2"
                                Text="{x:Bind Gateway, Mode=TwoWay}"
                                PlaceholderText="z.B. 192.168.1.1"
                                ToolTipService.ToolTip="Gateway" />
                            <TextBox
                                Grid.Column="3"
                                Text="{x:Bind Metric, Mode=TwoWay}"
                                PlaceholderText="1"
                                ToolTipService.ToolTip="Metrik > 0" />
                            <Button
                                Grid.Column="4"
                                Tag="{x:Bind}"
                                Click="RemoveRoute_Click"
                                ToolTipService.ToolTip="Route löschen"
                                HorizontalAlignment="Stretch"
                                Padding="10,8">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                    <TextBlock Text="Löschen" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Click="AddRoute_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                    <TextBlock Text="Route hinzufügen" />
                </StackPanel>
            </Button>
            <TextBlock Text="Leere Zeilen werden ignoriert." VerticalAlignment="Center" Opacity="0.8" />
        </StackPanel>
    </StackPanel>
</UserControl>
