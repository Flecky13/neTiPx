<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="neTiPx.Views.AdapterPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:neTiPx.ViewModels"
    mc:Ignorable="d">
    <Page.DataContext>
        <viewModels:AdapterViewModel />
    </Page.DataContext>

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="24">
            <!-- Header mit Image -->
            <Border Style="{StaticResource CardBorder}" Padding="24">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Adapter" Style="{StaticResource SectionTitle}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="Infos zu deine zwei Adaptern." />
                    </StackPanel>
                    <Image
                        Grid.Column="1"
                        Source="ms-appx:///Assets/toolicon.png"
                        Width="120"
                        Height="120"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- Informationen nebeneinander -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <!-- Informationen Primaerer Adapter -->
                <Border Style="{StaticResource CardBorder}" Grid.Column="0" Visibility="{Binding IsPrimaryAdapterSelected}">
                    <StackPanel Spacing="16">
                        <!-- Titel -->
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Netzwerkkarte 1" Style="{StaticResource SectionTitle}" FontSize="18" FontWeight="Bold" />
                        </StackPanel>

                        <!-- Name -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterName}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- MAC -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="MAC:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterMac}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- IPv4 Informationen Header -->
                        <TextBlock Text="IPv4 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0" />

                        <!-- IPv4 -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IPv4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <ItemsRepeater ItemsSource="{Binding PrimaryAdapterIpV4List}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>

                        <!-- Gateway -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterGateway}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- DNS4 -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <ItemsRepeater ItemsSource="{Binding PrimaryAdapterDns4List}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>

                        <StackPanel Visibility="{Binding IsPrimaryIpv6Available, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <!-- IPv6 Informationen Header -->
                            <TextBlock Text="IPv6 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0" />

                            <!-- IPv6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="IPv6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <ItemsRepeater ItemsSource="{Binding PrimaryAdapterIpV6List}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Grid>

                            <!-- Gateway6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway6:" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterGateway6}" TextWrapping="Wrap" />
                            </Grid>

                            <!-- DNS6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <ItemsRepeater ItemsSource="{Binding PrimaryAdapterDns6List}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Informationen Sekundaerer Adapter -->
                <Border Style="{StaticResource CardBorder}" Grid.Column="1" Visibility="{Binding IsSecondaryAdapterSelected}">
                    <StackPanel Spacing="16">
                        <!-- Titel -->
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Netzwerkkarte 2" Style="{StaticResource SectionTitle}" FontSize="18" FontWeight="Bold" />
                        </StackPanel>

                        <!-- Name -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterName}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- MAC -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="MAC:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterMac}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- IPv4 Informationen Header -->
                        <TextBlock Text="IPv4 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0" />

                        <!-- IPv4 -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IPv4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <ItemsRepeater ItemsSource="{Binding SecondaryAdapterIpV4List}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>

                        <!-- Gateway -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterGateway}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- DNS4 -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <ItemsRepeater ItemsSource="{Binding SecondaryAdapterDns4List}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>

                        <StackPanel Visibility="{Binding IsSecondaryIpv6Available, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <!-- IPv6 Informationen Header -->
                            <TextBlock Text="IPv6 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0" />

                            <!-- IPv6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="IPv6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <ItemsRepeater ItemsSource="{Binding SecondaryAdapterIpV6List}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Grid>

                            <!-- Gateway6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway6:" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterGateway6}" TextWrapping="Wrap" />
                            </Grid>

                            <!-- DNS6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <ItemsRepeater ItemsSource="{Binding SecondaryAdapterDns6List}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Verbindungsstatus -->
            <Border Style="{StaticResource CardBorder}" Padding="16" Visibility="{Binding ShowConnectionQualityIndicator, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Verbindungsstatus" Style="{StaticResource SectionTitle}" FontWeight="Bold" />

                    <!-- Gateway, DNS1, DNS2 nebeneinander -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
                        <!-- Gateway Status -->
                        <StackPanel Grid.Column="0" Spacing="4" Visibility="{Binding ShowGatewayStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Gateway" FontWeight="SemiBold" FontSize="12" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse
                                    Width="12"
                                    Height="12"
                                    Fill="{Binding GatewayStatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}"
                                    VerticalAlignment="Center" />
                                <TextBlock Text="{Binding GatewayStatusText}" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                            <TextBlock Text="{Binding PrimaryAdapterGateway}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding GatewayPingText}" FontSize="11" Opacity="0.7" />
                        </StackPanel>

                        <!-- DNS1 Status -->
                        <StackPanel Grid.Column="1" Spacing="4" Visibility="{Binding ShowDns1Status, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="DNS 1" FontWeight="SemiBold" FontSize="12" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse
                                    Width="12"
                                    Height="12"
                                    Fill="{Binding Dns1StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}"
                                    VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Dns1StatusText}" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                            <TextBlock Text="{Binding PrimaryDns1Address}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Dns1PingText}" FontSize="11" Opacity="0.7" />
                        </StackPanel>

                        <!-- DNS2 Status -->
                        <StackPanel Grid.Column="2" Spacing="4" Visibility="{Binding ShowDns2Status, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="DNS 2" FontWeight="SemiBold" FontSize="12" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse
                                    Width="12"
                                    Height="12"
                                    Fill="{Binding Dns2StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}"
                                    VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Dns2StatusText}" VerticalAlignment="Center" FontSize="12" />
                            </StackPanel>
                            <TextBlock Text="{Binding PrimaryDns2Address}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Dns2PingText}" FontSize="11" Opacity="0.7" />
                        </StackPanel>
                    </Grid>

                    <!-- Qualitäts-Ampel -->
                    <StackPanel Spacing="8" Visibility="{Binding ShowConnectionQualityIndicator, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Verbindungsqualität" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" />
                        <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="12" HorizontalAlignment="Center">
                            <Ellipse
                                Width="20"
                                Height="20"
                                Visibility="{Binding ShowGatewayStatus, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Fill="{Binding GatewayStatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}"
                                Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
                                StrokeThickness="1" />
                            <Ellipse
                                Grid.Column="1"
                                Width="20"
                                Height="20"
                                Visibility="{Binding ShowDns1Status, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Fill="{Binding Dns1StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}"
                                Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
                                StrokeThickness="1" />
                            <Ellipse
                                Grid.Column="2"
                                Width="20"
                                Height="20"
                                Visibility="{Binding ShowDns2Status, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Fill="{Binding Dns2StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}"
                                Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
                                StrokeThickness="1" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
