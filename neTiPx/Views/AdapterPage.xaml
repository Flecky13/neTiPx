<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="neTiPx.Views.AdapterPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:neTiPx.ViewModels"
    mc:Ignorable="d">
    <Page.DataContext>
        <viewModels:AdapterViewModel />
    </Page.DataContext>

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="24">
            <!-- Header mit Image -->
            <Border Style="{StaticResource CardBorder}" Padding="24">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="AdapterTitleText" Text="Adapter" Style="{StaticResource SectionTitle}" FontSize="24" FontWeight="Bold" />
                        <TextBlock x:Name="AdapterSubtitleText" Text="Infos zu deine zwei Adaptern." />
                    </StackPanel>
                    <Image
                        Grid.Column="1"
                        Source="ms-appx:///Assets/toolicon.png"
                        Width="120"
                        Height="120"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- Informationen und Status als 2x2 Grid -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="6">
                <!-- Informationen Primaerer Adapter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="0" Grid.Column="0" Visibility="{Binding IsPrimaryAdapterSelected}">
                    <StackPanel Spacing="14">
                        <!-- Titel -->
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock x:Name="Nic1Title" Text="Netzwerkkarte 1" Style="{StaticResource SectionTitle}" FontSize="16" FontWeight="Bold" />
                        </StackPanel>

                        <!-- Name -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock x:Name="LblName1" Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterName}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- MAC -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock x:Name="LblMac1" Grid.Row="0" Grid.Column="0" Text="MAC:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterMac}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- IPv4 Informationen Header -->
                        <TextBlock x:Name="LblIpv4Info1" Text="IPv4 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0"
                                   Visibility="{Binding IsPrimaryAdapterDown, Converter={StaticResource InvertedBooleanToVisibilityConverter}}" />

                        <!-- IPv4 -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock x:Name="LblIpv4_1" Grid.Row="0" Grid.Column="0" Text="IPv4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <ItemsRepeater ItemsSource="{Binding PrimaryAdapterIpV4List}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>

                        <!-- Gateway -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="6"
                              Visibility="{Binding IsPrimaryAdapterDown, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                            <TextBlock x:Name="LblGateway1" Grid.Row="0" Grid.Column="0" Text="Gateway:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterGateway}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- DNS4 -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="6"
                              Visibility="{Binding IsPrimaryAdapterDown, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                            <TextBlock x:Name="LblDns4_1" Grid.Row="0" Grid.Column="0" Text="DNS4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <ItemsRepeater ItemsSource="{Binding PrimaryAdapterDns4List}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>

                        <StackPanel Visibility="{Binding IsPrimaryIpv6Available, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <!-- IPv6 Informationen Header -->
                            <TextBlock x:Name="LblIpv6Info1" Text="IPv6 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0"
                                       Visibility="{Binding IsPrimaryAdapterDown, Converter={StaticResource InvertedBooleanToVisibilityConverter}}" />

                            <!-- IPv6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="6">
                                <TextBlock x:Name="LblIpv6_1" Grid.Row="0" Grid.Column="0" Text="IPv6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <ItemsRepeater ItemsSource="{Binding PrimaryAdapterIpV6List}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Grid>

                            <!-- Gateway6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="6"
                                  Visibility="{Binding IsPrimaryAdapterDown, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                                <TextBlock x:Name="LblGateway6_1" Grid.Row="0" Grid.Column="0" Text="Gateway6:" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterGateway6}" TextWrapping="Wrap" />
                            </Grid>

                            <!-- DNS6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="6"
                                  Visibility="{Binding IsPrimaryAdapterDown, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                                <TextBlock x:Name="LblDns6_1" Grid.Row="0" Grid.Column="0" Text="DNS6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <ItemsRepeater ItemsSource="{Binding PrimaryAdapterDns6List}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Informationen Sekundaerer Adapter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="0" Grid.Column="1" Visibility="{Binding IsSecondaryAdapterSelected}">
                    <StackPanel Spacing="14">
                        <!-- Titel -->
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock x:Name="Nic2Title" Text="Netzwerkkarte 2" Style="{StaticResource SectionTitle}" FontSize="16" FontWeight="Bold" />
                        </StackPanel>

                        <!-- Name -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock x:Name="LblName2" Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterName}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- MAC -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock x:Name="LblMac2" Grid.Row="0" Grid.Column="0" Text="MAC:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterMac}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- IPv4 Informationen Header -->
                        <TextBlock x:Name="LblIpv4Info2" Text="IPv4 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0"
                                   Visibility="{Binding IsSecondaryAdapterDown, Converter={StaticResource InvertedBooleanToVisibilityConverter}}" />

                        <!-- IPv4 -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock x:Name="LblIpv4_2" Grid.Row="0" Grid.Column="0" Text="IPv4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <ItemsRepeater ItemsSource="{Binding SecondaryAdapterIpV4List}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>

                        <!-- Gateway -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="6"
                              Visibility="{Binding IsSecondaryAdapterDown, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                            <TextBlock x:Name="LblGateway2" Grid.Row="0" Grid.Column="0" Text="Gateway:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterGateway}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- DNS4 -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="6"
                              Visibility="{Binding IsSecondaryAdapterDown, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                            <TextBlock x:Name="LblDns4_2" Grid.Row="0" Grid.Column="0" Text="DNS4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <ItemsRepeater ItemsSource="{Binding SecondaryAdapterDns4List}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>

                        <StackPanel Visibility="{Binding IsSecondaryIpv6Available, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <!-- IPv6 Informationen Header -->
                            <TextBlock x:Name="LblIpv6Info2" Text="IPv6 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0"
                                       Visibility="{Binding IsSecondaryAdapterDown, Converter={StaticResource InvertedBooleanToVisibilityConverter}}" />

                            <!-- IPv6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="6">
                                <TextBlock x:Name="LblIpv6_2" Grid.Row="0" Grid.Column="0" Text="IPv6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <ItemsRepeater ItemsSource="{Binding SecondaryAdapterIpV6List}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Grid>

                            <!-- Gateway6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="6"
                                  Visibility="{Binding IsSecondaryAdapterDown, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                                <TextBlock x:Name="LblGateway6_2" Grid.Row="0" Grid.Column="0" Text="Gateway6:" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterGateway6}" TextWrapping="Wrap" />
                            </Grid>

                            <!-- DNS6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="6"
                                  Visibility="{Binding IsSecondaryAdapterDown, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                                <TextBlock x:Name="LblDns6_2" Grid.Row="0" Grid.Column="0" Text="DNS6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <ItemsRepeater ItemsSource="{Binding SecondaryAdapterDns6List}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Grid.Row="1" Grid.Column="0" Visibility="{Binding IsPrimaryAdapterSelected}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="StatusNic1" Text="Status NIC 1" Style="{StaticResource SectionTitle}" FontWeight="Bold" />

                        <!-- Kein Link Banner (nur bei Adapter Down) -->
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    Visibility="{Binding IsPrimaryAdapterDown, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Ellipse Width="12" Height="12" Fill="{Binding GatewayStatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding GatewayStatusText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12"
                              Visibility="{Binding IsPrimaryAdapterDown, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="IPv4" FontWeight="SemiBold" FontSize="12" />

                                <StackPanel Spacing="4" Visibility="{Binding ShowGatewayStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Gateway" FontWeight="SemiBold" FontSize="12" />
                                    <Grid ColumnDefinitions="*,146" ColumnSpacing="10" MinHeight="58">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="12" Height="12" Fill="{Binding GatewayStatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding GatewayStatusText}" VerticalAlignment="Center" FontSize="12" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding PrimaryAdapterGateway}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding GatewayPingText}" FontSize="11" Opacity="0.7" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Height="58" BorderThickness="1" BorderBrush="{ThemeResource CardBorderBrush}" CornerRadius="4" Padding="0" Background="Transparent" VerticalAlignment="Stretch">
                                            <Polyline Points="{Binding GatewayTrendPoints}" Stroke="{Binding GatewayStatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="4" Visibility="{Binding ShowDns1Status, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="DNS 1" FontWeight="SemiBold" FontSize="12" />
                                    <Grid ColumnDefinitions="*,146" ColumnSpacing="10" MinHeight="58">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="12" Height="12" Fill="{Binding Dns1StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Dns1StatusText}" VerticalAlignment="Center" FontSize="12" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding PrimaryDns1Address}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Dns1PingText}" FontSize="11" Opacity="0.7" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Height="58" BorderThickness="1" BorderBrush="{ThemeResource CardBorderBrush}" CornerRadius="4" Padding="0" Background="Transparent" VerticalAlignment="Stretch">
                                            <Polyline Points="{Binding Dns1TrendPoints}" Stroke="{Binding Dns1StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="4" Visibility="{Binding ShowDns2Status, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="DNS 2" FontWeight="SemiBold" FontSize="12" />
                                    <Grid ColumnDefinitions="*,146" ColumnSpacing="10" MinHeight="58">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="12" Height="12" Fill="{Binding Dns2StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Dns2StatusText}" VerticalAlignment="Center" FontSize="12" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding PrimaryDns2Address}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Dns2PingText}" FontSize="11" Opacity="0.7" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Height="58" BorderThickness="1" BorderBrush="{ThemeResource CardBorderBrush}" CornerRadius="4" Padding="0" Background="Transparent" VerticalAlignment="Stretch">
                                            <Polyline Points="{Binding Dns2TrendPoints}" Stroke="{Binding Dns2StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="IPv6" FontWeight="SemiBold" FontSize="12" />

                                <StackPanel Spacing="4" Visibility="{Binding ShowGatewayStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Gateway" FontWeight="SemiBold" FontSize="12" />
                                    <Grid ColumnDefinitions="*,146" ColumnSpacing="10" MinHeight="58">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="12" Height="12" Fill="{Binding GatewayV6StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding GatewayV6StatusText}" VerticalAlignment="Center" FontSize="12" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding PrimaryAdapterGateway6}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding GatewayV6PingText}" FontSize="11" Opacity="0.7" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Height="58" BorderThickness="1" BorderBrush="{ThemeResource CardBorderBrush}" CornerRadius="4" Padding="0" Background="Transparent" VerticalAlignment="Stretch">
                                            <Polyline Points="{Binding GatewayV6TrendPoints}" Stroke="{Binding GatewayV6StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="4" Visibility="{Binding ShowDns1Status, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="DNS 1" FontWeight="SemiBold" FontSize="12" />
                                    <Grid ColumnDefinitions="*,146" ColumnSpacing="10" MinHeight="58">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="12" Height="12" Fill="{Binding Dns1V6StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Dns1V6StatusText}" VerticalAlignment="Center" FontSize="12" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding PrimaryDns1AddressV6}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Dns1V6PingText}" FontSize="11" Opacity="0.7" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Height="58" BorderThickness="1" BorderBrush="{ThemeResource CardBorderBrush}" CornerRadius="4" Padding="0" Background="Transparent" VerticalAlignment="Stretch">
                                            <Polyline Points="{Binding Dns1V6TrendPoints}" Stroke="{Binding Dns1V6StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="4" Visibility="{Binding ShowDns2Status, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="DNS 2" FontWeight="SemiBold" FontSize="12" />
                                    <Grid ColumnDefinitions="*,146" ColumnSpacing="10" MinHeight="58">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="12" Height="12" Fill="{Binding Dns2V6StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Dns2V6StatusText}" VerticalAlignment="Center" FontSize="12" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding PrimaryDns2AddressV6}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Dns2V6PingText}" FontSize="11" Opacity="0.7" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Height="58" BorderThickness="1" BorderBrush="{ThemeResource CardBorderBrush}" CornerRadius="4" Padding="0" Background="Transparent" VerticalAlignment="Stretch">
                                            <Polyline Points="{Binding Dns2V6TrendPoints}" Stroke="{Binding Dns2V6StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Grid.Row="1" Grid.Column="1" Visibility="{Binding IsSecondaryAdapterSelected}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="StatusNic2" Text="Status NIC 2" Style="{StaticResource SectionTitle}" FontWeight="Bold" />

                        <!-- Kein Link Banner (nur bei Adapter Down) -->
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    Visibility="{Binding IsSecondaryAdapterDown, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Ellipse Width="12" Height="12" Fill="{Binding SecondaryGatewayStatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SecondaryGatewayStatusText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12"
                              Visibility="{Binding IsSecondaryAdapterDown, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="IPv4" FontWeight="SemiBold" FontSize="12" />

                                <StackPanel Spacing="4" Visibility="{Binding ShowGatewayStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Gateway" FontWeight="SemiBold" FontSize="12" />
                                    <Grid ColumnDefinitions="*,146" ColumnSpacing="10" MinHeight="58">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="12" Height="12" Fill="{Binding SecondaryGatewayStatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding SecondaryGatewayStatusText}" VerticalAlignment="Center" FontSize="12" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding SecondaryAdapterGateway}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding SecondaryGatewayPingText}" FontSize="11" Opacity="0.7" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Height="58" BorderThickness="1" BorderBrush="{ThemeResource CardBorderBrush}" CornerRadius="4" Padding="0" Background="Transparent" VerticalAlignment="Stretch">
                                            <Polyline Points="{Binding SecondaryGatewayTrendPoints}" Stroke="{Binding SecondaryGatewayStatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="4" Visibility="{Binding ShowDns1Status, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="DNS 1" FontWeight="SemiBold" FontSize="12" />
                                    <Grid ColumnDefinitions="*,146" ColumnSpacing="10" MinHeight="58">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="12" Height="12" Fill="{Binding SecondaryDns1StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding SecondaryDns1StatusText}" VerticalAlignment="Center" FontSize="12" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding SecondaryDns1Address}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding SecondaryDns1PingText}" FontSize="11" Opacity="0.7" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Height="58" BorderThickness="1" BorderBrush="{ThemeResource CardBorderBrush}" CornerRadius="4" Padding="0" Background="Transparent" VerticalAlignment="Stretch">
                                            <Polyline Points="{Binding SecondaryDns1TrendPoints}" Stroke="{Binding SecondaryDns1StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Spacing="4" Visibility="{Binding ShowDns2Status, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="DNS 2" FontWeight="SemiBold" FontSize="12" />
                                    <Grid ColumnDefinitions="*,146" ColumnSpacing="10" MinHeight="58">
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="12" Height="12" Fill="{Binding SecondaryDns2StatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding SecondaryDns2StatusText}" VerticalAlignment="Center" FontSize="12" />
                                            </StackPanel>
