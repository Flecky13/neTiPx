<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="neTiPx.Views.InfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:neTiPx.ViewModels"
    mc:Ignorable="d">
    <Page.DataContext>
        <viewModels:InfoViewModel />
    </Page.DataContext>

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="24">
            <!-- Header mit Image (gleiche Höhe wie andere Pages) -->
            <Border Style="{StaticResource CardBorder}" Padding="24">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Info" Style="{StaticResource SectionTitle}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="Anwendungs Informationen, Hilfe, Update" />
                    </StackPanel>
                    <Image
                        Grid.Column="1"
                        Source="ms-appx:///Assets/toolicon.png"
                        Width="120"
                        Height="120"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- Versions-Info mit Update-Buttons -->
            <Border Style="{StaticResource CardBorder}" Padding="24">
                <Grid ColumnDefinitions="*,Auto">
                    <!-- Linke Seite: Versions-Informationen -->
                    <StackPanel Grid.Column="0" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="{Binding AppName}" FontSize="18" FontWeight="SemiBold" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="Installierte Version" Opacity="0.7" FontSize="12" />
                            <TextBlock Text="{Binding AppVersion}" FontSize="16" FontWeight="SemiBold" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Latest Version (GitHub)" Opacity="0.7" FontSize="12" />
                            <TextBlock Text="{Binding LatestVersion}" FontSize="16" FontWeight="SemiBold" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Ellipse
                                Width="10"
                                Height="10"
                                Fill="{Binding UpdateStatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                Text="Update-Status"
                                FontSize="12"
                                Opacity="0.7"
                                VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock
                            Text="{Binding UpdateStatus}"
                            FontSize="12"
                            Opacity="0.8"
                            TextWrapping="Wrap" />

                        <StackPanel Spacing="2">
                            <HyperlinkButton Content="GitHub Releases" NavigateUri="{Binding ReleasesUrl}" HorizontalAlignment="Left" Padding="0" />
                            <HyperlinkButton Content="Latest Release" NavigateUri="{Binding LatestReleaseUrl}" HorizontalAlignment="Left" Padding="0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Rechte Seite: Update-Buttons -->
                    <StackPanel Grid.Column="1" Spacing="12" VerticalAlignment="Center">
                        <Button
                            Command="{Binding CheckForUpdateCommand}"
                            HorizontalAlignment="Stretch"
                            MinWidth="200">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE895;" FontSize="16" />
                                <TextBlock Text="Auf Update Prüfen" />
                            </StackPanel>
                        </Button>

                        <Button
                            Command="{Binding InstallUpdateCommand}"
                            HorizontalAlignment="Stretch"
                            MinWidth="200"
                            Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE896;" FontSize="16" />
                                <TextBlock Text="Update Installieren" />
                            </StackPanel>
                        </Button>

                        <Button
                            Command="{Binding ShowChangelogCommand}"
                            HorizontalAlignment="Stretch"
                            MinWidth="200">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8F3;" FontSize="16" />
                                <TextBlock Text="Changelog / Release" />
                            </StackPanel>
                        </Button>

                        <Button
                            Command="{Binding ShowHelpCommand}"
                            HorizontalAlignment="Stretch"
                            MinWidth="200">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE897;" FontSize="16" />
                                <TextBlock Text="Hilfe" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Lizenz & Kontakt Section -->
            <Border Style="{StaticResource CardBorder}" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="Lizenz &amp; Kontakt" FontSize="18" FontWeight="SemiBold" />

                    <StackPanel Spacing="8">
                        <TextBlock
                            Text="Siehe LICENSE im Repository. Für Fragen zum Code bitte Issues/PRs im Repo verwenden."
                            FontSize="13"
                            Opacity="0.8"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                        <TextBlock Text="Kontakt:" Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Opacity="0.7" />
                        <HyperlinkButton
                            Grid.Row="0"
                            Grid.Column="1"
                            Content="https://github.com/Flecky13"
                            NavigateUri="https://github.com/Flecky13"
                            HorizontalAlignment="Left"
                            Padding="0" />

                        <TextBlock Text="Support:" Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Opacity="0.7" />
                        <HyperlinkButton
                            Grid.Row="1"
                            Grid.Column="1"
                            Content="https://buymeacoffee.com/pedrotepe"
                            NavigateUri="https://buymeacoffee.com/pedrotepe"
                            HorizontalAlignment="Left"
                            Padding="0" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
