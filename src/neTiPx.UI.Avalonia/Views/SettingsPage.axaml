<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="using:neTiPx.UI.Avalonia.Markup"
             xmlns:vm="using:neTiPx.UI.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="neTiPx.UI.Avalonia.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel">
    
    <ScrollViewer>
        <StackPanel Spacing="16" Margin="24">
            <!-- Header mit Image -->
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="24" 
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{loc:Loc SETTINGS_TITLE}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="{loc:Loc SETTINGS_SUBTITLE_PRE}" />
                    </StackPanel>
                    <Image Grid.Column="1"
                           Source="/Assets/toolicon.ico"
                           Width="120"
                           Height="120"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- 3x3 Grid für Konfigurationsbereiche -->
            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*,*" RowSpacing="16" ColumnSpacing="16">
                <!-- Oben Links: Netzwerkadapter -->
                <Border Grid.Row="0" Grid.Column="0" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{loc:Loc SETTINGS_ADAPTER_CARD}" FontWeight="Bold" />
                        <TextBlock Text="{loc:Loc SETTINGS_ADAPTER_DESC}" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="{loc:Loc SETTINGS_PRIMARY_ADAPTER}" FontWeight="SemiBold" FontSize="12" />
                            <ComboBox HorizontalAlignment="Stretch" 
                                      ItemsSource="{Binding AvailableAdapters}"
                                      SelectedItem="{Binding SelectedPrimaryAdapter}" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="{loc:Loc SETTINGS_SECONDARY_ADAPTER}" FontWeight="SemiBold" FontSize="12" />
                            <ComboBox HorizontalAlignment="Stretch" 
                                      ItemsSource="{Binding AvailableSecondaryAdapters}"
                                      SelectedItem="{Binding SelectedSecondaryAdapter}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Oben Mitte: Verbindungsqualität -->
                <Border Grid.Row="0" Grid.Column="1" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{loc:Loc SETTINGS_CONNECTION_QUALITY_TITLE}" FontWeight="Bold" />
                        <TextBlock Text="{loc:Loc SETTINGS_CONNECTION_QUALITY_DESC}" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />

                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="12" Height="12"
                                         Fill="{DynamicResource SuccessBrush}"
                                         Stroke="{DynamicResource SuccessBrush}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="{loc:Loc SETTINGS_FAST_MS}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                            <NumericUpDown Value="{Binding PingThresholdFast}" 
                                           Minimum="1" 
                                           Maximum="100" 
                                           Increment="5"
                                           HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="12" Height="12"
                                         Fill="{DynamicResource WarningBrush}"
                                         Stroke="{DynamicResource WarningBrush}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="{loc:Loc SETTINGS_NORMAL}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                            <NumericUpDown Value="{Binding PingThresholdNormal}" 
                                           Minimum="10" 
                                           Maximum="500" 
                                           Increment="10"
                                           HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="12" Height="12"
                                     Fill="{DynamicResource ErrorBrush}"
                                     Stroke="{DynamicResource ErrorBrush}"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="{loc:Loc SETTINGS_SLOW_MS}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Oben Rechts: Netzwerk -->
                <Border Grid.Row="0" Grid.Column="2" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{loc:Loc SETTINGS_PLACEHOLDER}" FontWeight="Bold" />
                        <TextBlock Text="{loc:Loc SETTINGS_PLACEHOLDER_DESC}" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Mitte Links: Ping-Logging -->
                <Border Grid.Row="1" Grid.Column="0" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{loc:Loc SETTINGS_PLACEHOLDER}" FontWeight="Bold" />
                        <TextBlock Text="{loc:Loc SETTINGS_PLACEHOLDER_DESC}" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Mitte Mitte: Desktop-Overlay -->
                <Border Grid.Row="1" Grid.Column="1" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{loc:Loc OVERLAY_SETTINGS_TITLE}" FontWeight="Bold" />
                        <TextBlock Text="{loc:Loc OVERLAY_SETTINGS_DESC}" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />

                        <CheckBox Content="{loc:Loc OVERLAY_ENABLE}"
                                  IsChecked="{Binding DesktopOverlayEnabled}" />

                        <Button HorizontalAlignment="Stretch" Click="OpenDesktopOverlaySettingsButton_OnClick">
                            <TextBlock Text="{loc:Loc OVERLAY_OPEN_SETTINGS}" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Mitte Rechts: Daten -->
                <Border Grid.Row="1" Grid.Column="2" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{loc:Loc SETTINGS_DATA}" FontWeight="Bold" />
                        <TextBlock Text="{loc:Loc SETTINGS_DATA_DESC}" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />

                        <Button HorizontalAlignment="Stretch" Click="ExportSettingsButton_OnClick">
                            <TextBlock Text="{loc:Loc SETTINGS_EXPORT}" />
                        </Button>
                        <Button HorizontalAlignment="Stretch" Click="ImportSettingsButton_OnClick">
                            <TextBlock Text="{loc:Loc SETTINGS_IMPORT}" />
                        </Button>
                        <Button HorizontalAlignment="Stretch" Click="ResetSettingsButton_OnClick">
                            <TextBlock Text="{loc:Loc SETTINGS_RESET}" Foreground="Red" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Unten Links: Erscheinungsbild -->
                <Border Grid.Row="2" Grid.Column="0" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{loc:Loc SETTINGS_DISPLAY}" FontWeight="Bold" />
                        <TextBlock Text="{loc:Loc SETTINGS_LANGUAGE_DESC}" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="{loc:Loc SETTINGS_COLORSCHEME}" FontWeight="SemiBold" FontSize="12" />
                            <ComboBox HorizontalAlignment="Stretch" 
                                      ItemsSource="{Binding AvailableThemes}"
                                      SelectedItem="{Binding SelectedTheme}" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="{loc:Loc SETTINGS_LANGUAGE}" FontWeight="SemiBold" FontSize="12" />
                            <ComboBox HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding AvailableLanguages}"
                                      SelectedItem="{Binding SelectedLanguage}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Unten Mitte: Autostart -->
                <Border Grid.Row="2" Grid.Column="1" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{loc:Loc SETTINGS_AUTOSTART}" FontWeight="Bold" />
                        <TextBlock Text="{loc:Loc SETTINGS_AUTOSTART_WINDOWS}" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />

                        <CheckBox Content="{loc:Loc SETTINGS_AUTOSTART_ENABLE}" 
                                  IsChecked="{Binding IsAutostartEnabled}" />
                        <TextBlock Text="{loc:Loc SETTINGS_AUTOSTART_HINT}" 
                                   FontSize="11" 
                                   Opacity="0.6" 
                                   TextWrapping="Wrap" 
                                   Margin="24,0,0,0" />
                        
                        <CheckBox Content="{loc:Loc SETTINGS_START_MINIMIZED}" 
                                  IsChecked="{Binding StartMinimizedToTray}"
                                  IsEnabled="{Binding IsAutostartEnabled}" />
                        <TextBlock Text="{loc:Loc SETTINGS_START_MINIMIZED_HINT}" 
                                   FontSize="11" 
                                   Opacity="0.6" 
                                   TextWrapping="Wrap" 
                                   Margin="24,0,0,0" />
                    </StackPanel>
                </Border>

                <!-- Unten Rechts: Info-Fenster -->
                <Border Grid.Row="2" Grid.Column="2" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{loc:Loc SETTINGS_HOVER_WINDOW}" FontWeight="Bold" />
                        <TextBlock Text="{loc:Loc SETTINGS_HOVER_WINDOW_DESC}" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />

                        <StackPanel Spacing="8">
                            <!-- Position -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="{loc:Loc SETTINGS_POSITION}" FontWeight="SemiBold" FontSize="12" />
                                <ComboBox HorizontalAlignment="Stretch" 
                                          SelectedIndex="{Binding HoverWindowPositionIndex}">
                                    <ComboBoxItem Content="{loc:Loc SETTINGS_POS_TOP}" />
                                    <ComboBoxItem Content="{loc:Loc SETTINGS_POS_BOTTOM}" />
                                </ComboBox>
                            </StackPanel>

                            <!-- Abstände -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{loc:Loc SETTINGS_OFFSET_HORIZONTAL}" FontWeight="SemiBold" FontSize="12" />
                                    <NumericUpDown Value="{Binding HoverWindowRightOffset}" 
                                                   Minimum="0" Maximum="5000" Increment="10" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{loc:Loc SETTINGS_OFFSET_VERTICAL}" FontWeight="SemiBold" FontSize="12" />
                                    <NumericUpDown Value="{Binding HoverWindowVerticalOffset}" 
                                                   Minimum="0" Maximum="5000" Increment="10" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
