<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:neTiPx.UI.Avalonia.ViewModels"
             xmlns:converters="using:neTiPx.UI.Avalonia.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="neTiPx.UI.Avalonia.Views.AdapterPage"
             x:DataType="vm:AdapterViewModel">
    
    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
    </UserControl.Resources>
    
    <ScrollViewer>
        <StackPanel Spacing="16" Margin="24">
            <!-- Header mit Image -->
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="24" 
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Adapter" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="Infos zu deinen zwei Adaptern." />
                    </StackPanel>
                    <Image Grid.Column="1"
                           Source="/Assets/toolicon.ico"
                           Width="120"
                           Height="120"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- Informationen und Status als 2x2 Grid -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="16">
                
                <!-- Informationen Primärer Adapter -->
                <Border Grid.Row="0" Grid.Column="0" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        IsVisible="{Binding IsPrimaryAdapterVisible}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Netzwerkkarte 1" FontSize="16" FontWeight="Bold" />

                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterName}" TextWrapping="Wrap" />
                        </Grid>

                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="MAC:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterMac}" TextWrapping="Wrap" />
                        </Grid>

                        <TextBlock Text="IPv4 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0" 
                                   IsVisible="{Binding !IsPrimaryAdapterDown}" />

                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IPv4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding PrimaryAdapterIpV4List}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <Grid ColumnDefinitions="140,*" RowSpacing="6" IsVisible="{Binding !IsPrimaryAdapterDown}">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterGateway}" TextWrapping="Wrap" />
                        </Grid>

                        <Grid ColumnDefinitions="140,*" RowSpacing="6" IsVisible="{Binding !IsPrimaryAdapterDown}">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding PrimaryAdapterDns4List}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <StackPanel IsVisible="{Binding IsPrimaryIpv6Available}">
                            <TextBlock Text="IPv6 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0" 
                                       IsVisible="{Binding !IsPrimaryAdapterDown}" />

                            <Grid ColumnDefinitions="140,*" RowSpacing="6" Margin="0,8,0,0">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="IPv6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding PrimaryAdapterIpV6List}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <Grid ColumnDefinitions="140,*" RowSpacing="6" IsVisible="{Binding !IsPrimaryAdapterDown}">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway6:" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterGateway6}" TextWrapping="Wrap" />
                            </Grid>

                            <Grid ColumnDefinitions="140,*" RowSpacing="6" IsVisible="{Binding !IsPrimaryAdapterDown}">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding PrimaryAdapterDns6List}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Informationen Sekundärer Adapter -->
                <Border Grid.Row="0" Grid.Column="1" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        IsVisible="{Binding IsSecondaryAdapterVisible}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Netzwerkkarte 2" FontSize="16" FontWeight="Bold" />

                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterName}" TextWrapping="Wrap" />
                        </Grid>

                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="MAC:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterMac}" TextWrapping="Wrap" />
                        </Grid>

                        <TextBlock Text="IPv4 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0" 
                                   IsVisible="{Binding !IsSecondaryAdapterDown}" />

                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IPv4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding SecondaryAdapterIpV4List}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <Grid ColumnDefinitions="140,*" RowSpacing="6" IsVisible="{Binding !IsSecondaryAdapterDown}">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterGateway}" TextWrapping="Wrap" />
                        </Grid>

                        <Grid ColumnDefinitions="140,*" RowSpacing="6" IsVisible="{Binding !IsSecondaryAdapterDown}">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding SecondaryAdapterDns4List}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <StackPanel IsVisible="{Binding IsSecondaryIpv6Available}">
                            <TextBlock Text="IPv6 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0" 
                                       IsVisible="{Binding !IsSecondaryAdapterDown}" />

                            <Grid ColumnDefinitions="140,*" RowSpacing="6" Margin="0,8,0,0">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="IPv6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding SecondaryAdapterIpV6List}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <Grid ColumnDefinitions="140,*" RowSpacing="6" IsVisible="{Binding !IsSecondaryAdapterDown}">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway6:" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterGateway6}" TextWrapping="Wrap" />
                            </Grid>

                            <Grid ColumnDefinitions="140,*" RowSpacing="6" IsVisible="{Binding !IsSecondaryAdapterDown}">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <ItemsControl Grid.Row="0" Grid.Column="1" ItemsSource="{Binding SecondaryAdapterDns6List}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Status Primärer Adapter -->
                <Border Grid.Row="1" Grid.Column="0" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        IsVisible="{Binding IsPrimaryAdapterVisible}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Status - NIC 1" FontSize="16" FontWeight="Bold" />
                        
                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway:" FontWeight="SemiBold" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush>
                                                <SolidColorBrush.Color>
                                                    <MultiBinding Converter="{StaticResource StatusToColorConverter}">
                                                        <Binding Path="GatewayStatusKind" />
                                                    </MultiBinding>
                                                </SolidColorBrush.Color>
                                            </SolidColorBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="{Binding GatewayStatusText}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding GatewayPingText}" FontSize="11" Opacity="0.7"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS1:" FontWeight="SemiBold" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush>
                                                <SolidColorBrush.Color>
                                                    <MultiBinding Converter="{StaticResource StatusToColorConverter}">
                                                        <Binding Path="Dns1StatusKind" />
                                                    </MultiBinding>
                                                </SolidColorBrush.Color>
                                            </SolidColorBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="{Binding Dns1StatusText}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Dns1PingText}" FontSize="11" Opacity="0.7"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS2:" FontWeight="SemiBold" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush>
                                                <SolidColorBrush.Color>
                                                    <MultiBinding Converter="{StaticResource StatusToColorConverter}">
                                                        <Binding Path="Dns2StatusKind" />
                                                    </MultiBinding>
                                                </SolidColorBrush.Color>
                                            </SolidColorBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="{Binding Dns2StatusText}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Dns2PingText}" FontSize="11" Opacity="0.7"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Status Sekundärer Adapter -->
                <Border Grid.Row="1" Grid.Column="1" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        IsVisible="{Binding IsSecondaryAdapterVisible}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Status - NIC 2" FontSize="16" FontWeight="Bold" />
                        
                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway:" FontWeight="SemiBold" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush>
                                                <SolidColorBrush.Color>
                                                    <MultiBinding Converter="{StaticResource StatusToColorConverter}">
                                                        <Binding Path="SecondaryGatewayStatusKind" />
                                                    </MultiBinding>
                                                </SolidColorBrush.Color>
                                            </SolidColorBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="{Binding SecondaryGatewayStatusText}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SecondaryGatewayPingText}" FontSize="11" Opacity="0.7"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS1:" FontWeight="SemiBold" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush>
                                                <SolidColorBrush.Color>
                                                    <MultiBinding Converter="{StaticResource StatusToColorConverter}">
                                                        <Binding Path="SecondaryDns1StatusKind" />
                                                    </MultiBinding>
                                                </SolidColorBrush.Color>
                                            </SolidColorBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="{Binding SecondaryDns1StatusText}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SecondaryDns1PingText}" FontSize="11" Opacity="0.7"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="140,*" RowSpacing="6">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS2:" FontWeight="SemiBold" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush>
                                                <SolidColorBrush.Color>
                                                    <MultiBinding Converter="{StaticResource StatusToColorConverter}">
                                                        <Binding Path="SecondaryDns2StatusKind" />
                                                    </MultiBinding>
                                                </SolidColorBrush.Color>
                                            </SolidColorBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="{Binding SecondaryDns2StatusText}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SecondaryDns2PingText}" FontSize="11" Opacity="0.7"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
