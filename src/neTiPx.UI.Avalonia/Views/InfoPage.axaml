<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:loc="using:neTiPx.UI.Avalonia.Markup"
             xmlns:vm="using:neTiPx.UI.Avalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="neTiPx.UI.Avalonia.Views.InfoPage"
             x:DataType="vm:InfoViewModel">
    
    <Design.DataContext>
        <vm:InfoViewModel />
    </Design.DataContext>
    
    <ScrollViewer>
        <StackPanel Spacing="16" Margin="24">
            <!-- Header mit Image -->
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="24" 
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{loc:Loc INFO_TITLE}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="{loc:Loc INFO_SUBTITLE}" />
                    </StackPanel>
                    <Image Grid.Column="1"
                           Source="/Assets/toolicon.ico"
                           Width="120"
                           Height="120"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- Versions-Info mit Update-Buttons -->
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="24"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                <Grid ColumnDefinitions="*,Auto">
                    <!-- Linke Seite: Versions-Informationen -->
                    <StackPanel Grid.Column="0" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc INFO_APP_NAME}" FontSize="18" FontWeight="SemiBold" />
                        
                        <!-- Versionen in einer Zeile -->
                        <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="24" RowDefinitions="Auto,Auto">
                            <!-- Installierte Version -->
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{loc:Loc INFO_INSTALLED_VERSION}" Opacity="0.7" FontSize="12" />
                                <TextBlock Text="{Binding AppVersion}" FontSize="16" FontWeight="SemiBold" />
                            </StackPanel>

                            <!-- Latest Version -->
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{loc:Loc INFO_LATEST_VERSION}" Opacity="0.7" FontSize="12" />
                                <TextBlock Text="{Binding LatestVersion}" FontSize="16" FontWeight="SemiBold" />
                            </StackPanel>

                            <!-- Update Status -->
                            <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc INFO_UPDATE_STATUS}" Opacity="0.7" FontSize="12" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="10" Height="10" Fill="{Binding UpdateStatusColor}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding UpdateStatusText}" FontSize="12" Opacity="0.8" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="4">
                            <TextBlock Text="{loc:Loc INFO_PLATFORM}" Opacity="0.7" FontSize="12" />
                            <TextBlock Text="{Binding PlatformInfo}" FontSize="14" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Rechte Seite: Update-Buttons -->
                    <StackPanel Grid.Column="1" Spacing="12" VerticalAlignment="Center">
                        <Button HorizontalAlignment="Stretch" MinWidth="200"
                                Command="{Binding CheckForUpdatesCommand}"
                                IsEnabled="{Binding !IsChecking}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="🔍" FontSize="16" />
                                <TextBlock Text="{loc:Loc INFO_CHECK_UPDATE}" />
                            </StackPanel>
                        </Button>

                        <!-- Update-Button nur sichtbar wenn Update verfügbar -->
                        <Button HorizontalAlignment="Stretch" MinWidth="200" Classes="accent"
                                IsVisible="{Binding IsUpdateAvailable}"
                                Command="{Binding DownloadUpdateCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="⬇️" FontSize="16" />
                                <TextBlock Text="{loc:Loc INFO_INSTALL_UPDATE}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- About -->
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="24"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                <Grid ColumnDefinitions="*,Auto">
                    <!-- Linke Seite: Text und Features -->
                    <StackPanel Grid.Column="0" Spacing="12" Margin="0,0,24,0">
                        <TextBlock Text="{loc:Loc INFO_ABOUT_TITLE}" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{loc:Loc INFO_ABOUT_TEXT}" TextWrapping="Wrap" />
                        
                        <Separator Margin="0,8" />
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:Loc INFO_DEVELOPED_BY}" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:Loc INFO_COPYRIGHT}" Opacity="0.7" />
                        </StackPanel>

                        <StackPanel Spacing="4" Margin="0,8,0,0">
                            <TextBlock Text="{loc:Loc INFO_FEATURES}" FontWeight="SemiBold" />
                            <TextBlock Text="{loc:Loc INFO_FEATURE_1}" />
                            <TextBlock Text="{loc:Loc INFO_FEATURE_2}" />
                            <TextBlock Text="{loc:Loc INFO_FEATURE_3}" />
                            <TextBlock Text="{loc:Loc INFO_FEATURE_4}" />
                            <TextBlock Text="{loc:Loc INFO_FEATURE_5}" />
                            <TextBlock Text="{loc:Loc INFO_FEATURE_6}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Rechte Seite: Buttons untereinander -->
                    <StackPanel Grid.Column="1" Spacing="12" VerticalAlignment="Center">
                        <Button Classes="accent" Command="{Binding OpenDocumentationCommand}" HorizontalAlignment="Stretch" MinWidth="200">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="📄" />
                                <TextBlock Text="{loc:Loc INFO_DOCUMENTATION}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenBugReportCommand}" HorizontalAlignment="Stretch" MinWidth="200">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="🐛" />
                                <TextBlock Text="{loc:Loc INFO_BUG_REPORT}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenGitHubRepositoryCommand}" HorizontalAlignment="Stretch" MinWidth="200">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="⭐" />
                                <TextBlock Text="{loc:Loc INFO_GITHUB_REPOSITORY}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenSupportCommand}" HorizontalAlignment="Stretch" MinWidth="200" Background="#756600" Foreground="#000000">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="☕" />
                                <TextBlock Text="{loc:Loc INFO_BUY_COFFEE}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Lizenz & Kontakt -->
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="24"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                <StackPanel Spacing="16">
                    <TextBlock Text="{loc:Loc INFO_LICENSE_TITLE}" FontSize="18" FontWeight="SemiBold" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="{loc:Loc INFO_LICENSE_TEXT}"
                                   FontSize="13"
                                   Opacity="0.8"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
