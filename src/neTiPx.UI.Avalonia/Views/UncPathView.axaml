<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:loc="using:neTiPx.UI.Avalonia.Markup"
             xmlns:vm="using:neTiPx.UI.Avalonia.ViewModels"
             xmlns:models="using:neTiPx.Core.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="neTiPx.UI.Avalonia.Views.UncPathView"
             x:DataType="vm:UncPathViewModel">
    
    <StackPanel Spacing="16">
           <TextBlock Text="{loc:Loc TOOLS_UNC_PATH}" FontSize="20" FontWeight="SemiBold" />

        <!-- Hauptbereich: Profile (Links) | Konfiguration (Mitte) | Status (Rechts) -->
        <Grid ColumnDefinitions="200,*,210" ColumnSpacing="16">
            <!-- Linker Bereich: UNC-Profile Liste -->
            <Border Grid.Column="0" 
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                <StackPanel Spacing="12">
                    <TextBlock Text="{loc:Loc IPCONFIG_UNC_PROFILE}" FontWeight="Bold" />

                    <!-- Profil-Liste -->
                    <ListBox ItemsSource="{Binding UncPathProfiles}"
                             SelectedItem="{Binding SelectedProfile}"
                             MinHeight="300"
                             MaxHeight="400"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="models:UncPathProfile">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Command="{Binding $parent[UserControl].((vm:UncPathViewModel)DataContext).DeleteProfileCommand}"
                                            CommandParameter="{Binding}"
                                            Padding="4"
                                            Background="Transparent">
                                        <PathIcon Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                  Width="14" Height="14"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Buttons -->
                    <Button Command="{Binding AddProfileCommand}"
                            HorizontalAlignment="Stretch"
                            Classes="accent">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" 
                                      Width="16" Height="16"/>
                            <TextBlock Text="{loc:Loc IPCONFIG_NEW_PROFILE}"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding CopyProfileCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" 
                                      Width="16" Height="16"/>
                            <TextBlock Text="{loc:Loc IPCONFIG_COPY_PROFILE}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Mittlerer Bereich: Profil-Einstellungen -->
            <Border Grid.Column="1" 
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    IsEnabled="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12" IsVisible="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}">
                        
                        <!-- Profilname -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="{loc:Loc IPCONFIG_PROFILE_NAME}" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding SelectedProfile.Name}" 
                                     Watermark="{loc:Loc UNC_PROFILE_PLACEHOLDER}"
                                     Classes.error="{Binding HasNameError}"/>
                            <TextBlock Text="{Binding NameErrorMessage}"
                                       Foreground="Red"
                                       FontSize="11"
                                       IsVisible="{Binding HasNameError}"/></StackPanel>

                        <!-- UNC Pfade Liste -->
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="{loc:Loc TOOLS_UNC_PATH}" FontWeight="SemiBold"/>
                                <Button Grid.Column="1"
                                    Content="{loc:Loc UNC_ADD}"
                                        Command="{Binding AddUncPathCommand}"
                                        Padding="8,4"
                                        FontSize="12"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding SelectedProfile.UncPaths}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models:UncPathEntry">
                                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="12"
                                                Margin="0,4">
                                            <StackPanel Spacing="8">
                                                <!-- Erste Zeile: Laufwerk/Mount-Point + UNC Pfad -->
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                    <!-- Windows: Laufwerksbuchstabe ComboBox -->
                                                    <StackPanel Grid.Column="0" Spacing="4" 
                                                                IsVisible="{Binding $parent[UserControl].((vm:UncPathViewModel)DataContext).IsWindows}">
                                                        <TextBlock Text="{Binding $parent[UserControl].((vm:UncPathViewModel)DataContext).MountTargetLabel}" 
                                                                   FontSize="12" FontWeight="SemiBold"/>
                                                        <ComboBox MinWidth="95"
                                                                  MaxWidth="95"
                                                                  ItemsSource="{Binding $parent[UserControl].((vm:UncPathViewModel)DataContext).DriveLetters}"
                                                                  SelectedItem="{Binding DriveLetter}"
                                                                  PlaceholderText="Laufwerk" />
                                                    </StackPanel>

                                                    <!-- Linux/macOS: Mount-Point TextBox -->
                                                    <StackPanel Grid.Column="0" Spacing="4" 
                                                                IsVisible="{Binding $parent[UserControl].((vm:UncPathViewModel)DataContext).IsUnixLike}">
                                                        <TextBlock Text="{Binding $parent[UserControl].((vm:UncPathViewModel)DataContext).MountTargetLabel}" 
                                                                   FontSize="12" FontWeight="SemiBold"/>
                                                        <TextBox MinWidth="150"
                                                                 Text="{Binding MountPoint}"
                                                                 Watermark="{Binding $parent[UserControl].((vm:UncPathViewModel)DataContext).MountTargetPlaceholder}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <TextBlock Text="{loc:Loc UNC_PATH_LABEL}" FontSize="12" FontWeight="SemiBold"/>
                                                        <TextBox Text="{Binding UncPath}"
                                                                 Watermark="{loc:Loc UNC_PATH_PLACEHOLDER}"
                                                                 Classes.error="{Binding HasUncPathError}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Zweite Zeile: Benutzername + Passwort -->
                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                        <TextBlock Text="{loc:Loc UNC_USERNAME}" FontSize="12"/>
                                                        <TextBox Text="{Binding Username}"
                                                                 Watermark="{loc:Loc UNC_USERNAME_PLACEHOLDER}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <TextBlock Text="{loc:Loc UNC_PASSWORD}" FontSize="12"/>
                                                        <TextBox Text="{Binding Password}"
                                                                 PasswordChar="●"
                                                                 Watermark="{loc:Loc UNC_PASSWORD}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Entfernen Button -->
                                                <Button Content="{loc:Loc UNC_REMOVE}"
                                                        Command="{Binding $parent[UserControl].((vm:UncPathViewModel)DataContext).RemoveUncPathCommand}"
                                                        CommandParameter="{Binding}"
                                                        HorizontalAlignment="Right"
                                                        IsEnabled="{Binding CanRemove}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Rechter Bereich: oben Aktionen, unten aktive Verbindungen -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*" RowSpacing="16">
                <Border Grid.Row="0" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{loc:Loc IPCONFIG_ACTIONS}" FontWeight="Bold" />

                        <StackPanel Spacing="8">
                            <Button Command="{Binding ApplyProfileCommand}"
                                    HorizontalAlignment="Stretch"
                                    Classes="accent">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <PathIcon Data="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z" 
                                              Width="14" Height="14"/>
                                    <TextBlock Text="{loc:Loc IPCONFIG_APPLY}" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SaveProfileCommand}"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <PathIcon Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" 
                                              Width="14" Height="14"/>
                                    <TextBlock Text="{loc:Loc IPCONFIG_SAVE}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <ProgressBar IsIndeterminate="{Binding IsApplying}"
                                     IsVisible="{Binding IsApplying}"
                                     Height="4"/>

                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10">
                            <TextBlock Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap"
                                       FontSize="11"
                                       Opacity="0.8"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" 
                                       Text="{loc:Loc UNC_CONNECTED_PATHS}" 
                                       FontWeight="Bold" 
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Command="{Binding RefreshMountedConnectionsCommand}"
                                    Padding="6"
                                    ToolTip.Tip="{loc:Loc LOGVIEWER_BUTTON_RELOAD}">
                                <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" 
                                          Width="14" Height="14"/>
                            </Button>
                        </Grid>

                        <ListBox ItemsSource="{Binding MountedConnections}"
                                 SelectionMode="Single"
                                 MinHeight="200"
                                 MaxHeight="380"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="models:MountedUncConnection">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <TextBox Grid.Column="0"
                                                 IsReadOnly="True"
                                                 Text="{Binding DisplayText}"
                                                 ToolTip.Tip="{Binding UncPath}"/>

                                        <Button Grid.Column="1"
                                                Padding="4"
                                                Command="{Binding $parent[UserControl].((vm:UncPathViewModel)DataContext).DisconnectMountedConnectionCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{loc:Loc UNC_DISCONNECT}">
                                            <PathIcon Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                                      Width="14" Height="14"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <TextBlock Text="{loc:Loc UNC_NONE_CONNECTED}"
                                   Opacity="0.6"
                                   HorizontalAlignment="Center"
                                   Margin="0,20"
                                   IsVisible="{Binding !MountedConnections.Count}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </StackPanel>
</UserControl>
