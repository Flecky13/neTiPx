<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:neTiPx.UI.Avalonia.ViewModels"
        xmlns:views="using:neTiPx.UI.Avalonia.Views"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="neTiPx.UI.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="neTiPx"
        Width="1200" Height="700"
        MinWidth="800" MinHeight="600"
        Icon="/Assets/toolicon.ico">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="40,*">
        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{DynamicResource SystemAccentColor}" Padding="12,6">
            <TextBlock Text="neTiPx" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White" />
        </Border>

        <!-- Navigation Layout -->
        <SplitView Grid.Row="1"
                   IsPaneOpen="{Binding IsPaneOpen}"
                   DisplayMode="CompactInline"
                   OpenPaneLength="240"
                   CompactPaneLength="48"
                   Background="{DynamicResource SystemControlBackgroundAltMediumBrush}">
            
            <!-- Navigation Pane -->
            <SplitView.Pane>
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Toggle Button -->
                    <Button Grid.Row="0" 
                            Command="{Binding TogglePaneCommand}"
                            Background="Transparent"
                            HorizontalAlignment="Left"
                            Margin="2"
                            Padding="2">
                        <TextBlock Text="☰" FontSize="18" />
                    </Button>

                    <!-- Navigation Items -->
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding NavigationItems}"
                             SelectedItem="{Binding SelectedNavigationItem}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="0,8,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding $parent[Window].DataContext.NavigateToCommand}"
                                        CommandParameter="{Binding Name}"
                                        Background="Transparent"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="2,6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding Icon}" FontSize="16" VerticalAlignment="Center" Width="20" TextAlignment="Center" />
                                        <TextBlock Text="{Binding DisplayName}" 
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding $parent[Window].DataContext.IsPaneOpen}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Footer -->
                    <TextBlock Grid.Row="2"
                               Text="© neTiPx by Pedro"
                               Margin="16,8"
                               FontSize="12"
                               Opacity="0.7"
                               VerticalAlignment="Bottom"
                               IsVisible="{Binding IsPaneOpen}" />
                </Grid>
            </SplitView.Pane>

            <!-- Content Area -->
            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                <ContentControl Content="{Binding CurrentPage}" />
            </Border>
        </SplitView>
    </Grid>
</Window>
