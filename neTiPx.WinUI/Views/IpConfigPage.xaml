<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="neTiPx.WinUI.Views.IpConfigPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:neTiPx.WinUI.Models"
    xmlns:viewModels="using:neTiPx.WinUI.ViewModels"
    mc:Ignorable="d">
    <Page.DataContext>
        <viewModels:IpConfigViewModel />
    </Page.DataContext>

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="24">
            <!-- Header mit Image -->
            <Border Style="{StaticResource CardBorder}" Padding="24">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IP Konfiguration" Style="{StaticResource SectionTitle}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="Verwalte die Netzwerkeinstellungen" />
                    </StackPanel>
                    <Image
                        Grid.Column="1"
                        Source="ms-appx:///images/toolicon.png"
                        Width="120"
                        Height="120"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,280">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <VisualState x:Name="WideState">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="900" />
                            </VisualState.StateTriggers>
                        </VisualState>
                        <VisualState x:Name="NarrowState">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="0" />
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter Target="StatusCardGrid.(Grid.Column)" Value="0" />
                                <Setter Target="StatusCardGrid.(Grid.ColumnSpan)" Value="1" />
                                <Setter Target="MainContent.(Grid.Column)" Value="0" />
                                <Setter Target="MainContent.(Grid.ColumnSpan)" Value="1" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <StackPanel Grid.Column="0" Spacing="16" x:Name="MainContent">
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Adapter" Style="{StaticResource SectionTitle}" />
                            <ComboBox
                                ItemsSource="{Binding AdapterList}"
                                SelectedItem="{Binding SelectedAdapter, Mode=TwoWay}"
                                PlaceholderText="Adapter Auswahl" />
                            <TextBlock Text="IP Modus" FontWeight="SemiBold" />
                            <RadioButtons ItemsSource="{Binding IpModeOptions}" SelectedItem="{Binding SelectedIpMode, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Gateway und DNS" Style="{StaticResource SectionTitle}" />
                            <TextBox Text="{Binding GatewayAddress, Mode=TwoWay}" PlaceholderText="Gateway" IsEnabled="{Binding IsManual}" />
                            <TextBox Text="{Binding DnsServer, Mode=TwoWay}" PlaceholderText="DNS Server" IsEnabled="{Binding IsManual}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="IP Adressen" Style="{StaticResource SectionTitle}" />
                            <Grid ColumnDefinitions="*,*,Auto" Margin="0,0,0,8">
                                <TextBlock Text="IP Adresse" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Subnetz" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="Aktion" FontWeight="SemiBold" />
                            </Grid>
                            <ItemsRepeater ItemsSource="{Binding IpAddresses}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:IpAddressEntry">
                                        <Grid ColumnDefinitions="*,*,Auto" Margin="0,0,0,8">
                                            <TextBox Text="{x:Bind IpAddress, Mode=TwoWay}" PlaceholderText="192.168.0.10" IsEnabled="{Binding DataContext.IsManual, ElementName=PageRoot}" />
                                            <TextBox Grid.Column="1" Text="{x:Bind SubnetMask, Mode=TwoWay}" PlaceholderText="255.255.255.0" IsEnabled="{Binding DataContext.IsManual, ElementName=PageRoot}" />
                                            <Button
                                                Grid.Column="2"
                                                Command="{Binding DataContext.RemoveIpCommand, ElementName=PageRoot}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding DataContext.IsManual, ElementName=PageRoot}">
                                                <FontIcon Glyph="&#xE74D;" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                            <Button HorizontalAlignment="Left" Command="{Binding AddIpCommand}" IsEnabled="{Binding IsManual}">IP Adresse hinzufuegen</Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border x:Name="StatusCardGrid" Grid.Column="1" Style="{StaticResource CardBorder}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Gateway Status" Style="{StaticResource SectionTitle}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse
                                Width="10"
                                Height="10"
                                Fill="{Binding GatewayStatusKind, Converter={StaticResource GatewayStatusToBrushConverter}}"
                                VerticalAlignment="Center" />
                            <TextBlock Text="{Binding GatewayStatusText}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding GatewayAddress}" />
                        <TextBlock Text="{Binding GatewayPingText}" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                <Button Style="{StaticResource PrimaryAction}" Command="{Binding ApplyCommand}">Anwenden</Button>
                <Button Command="{Binding SaveCommand}">Speichern</Button>
                <Button Command="{Binding CloseCommand}">Schliessen</Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
