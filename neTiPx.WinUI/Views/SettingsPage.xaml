<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="neTiPx.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="24">
            <!-- Header mit Image -->
            <Border Style="{StaticResource CardBorder}" Padding="24">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Einstellungen" Style="{StaticResource SectionTitle}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="Konfigurieren das Tool nach ihren Wünschen" />
                    </StackPanel>
                    <Image
                        Grid.Column="1"
                        Source="ms-appx:///Assets/toolicon.png"
                        Width="120"
                        Height="120"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- 3x3 Grid für Konfigurationsbereiche -->
            <Grid RowSpacing="16" ColumnSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Oben Links: Theme -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="0" Grid.Column="0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Theme" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Wählen Sie das Erscheinungsbild" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                        <ComboBox
                            x:Name="ThemeCombo"
                            HorizontalAlignment="Stretch"
                            SelectionChanged="ThemeCombo_SelectionChanged" />
                    </StackPanel>
                </Border>

                <!-- Oben Mitte: Platzhalter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="0" Grid.Column="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Zukünftige Konfiguration" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Oben Rechts: Platzhalter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="0" Grid.Column="2">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Zukünftige Konfiguration" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Mitte Links: Platzhalter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="1" Grid.Column="0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Zukünftige Konfiguration" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Mitte Mitte: Platzhalter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="1" Grid.Column="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Zukünftige Konfiguration" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Mitte Rechts: Platzhalter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="1" Grid.Column="2">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Zukünftige Konfiguration" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Unten Links: Platzhalter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="2" Grid.Column="0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Zukünftige Konfiguration" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Unten Mitte: Platzhalter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="2" Grid.Column="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Zukünftige Konfiguration" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Unten Rechts: Platzhalter -->
                <Border Style="{StaticResource CardBorder}" Grid.Row="2" Grid.Column="2">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Platzhalter" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Zukünftige Konfiguration" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
