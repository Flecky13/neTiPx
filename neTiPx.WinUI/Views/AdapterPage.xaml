<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="neTiPx.WinUI.Views.AdapterPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:neTiPx.WinUI.ViewModels"
    mc:Ignorable="d">
    <Page.DataContext>
        <viewModels:AdapterViewModel />
    </Page.DataContext>

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="24">
            <!-- Header mit Image -->
            <Border Style="{StaticResource CardBorder}" Padding="24">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Adapter" Style="{StaticResource SectionTitle}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="Wähle bis zu zwei Adapter für die Anzeige." />
                    </StackPanel>
                    <Image
                        Grid.Column="1"
                        Source="ms-appx:///Assets/toolicon.png"
                        Width="120"
                        Height="120"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- Dropdown Menüs nebeneinander -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <!-- Primaerer Adapter Text -->
                <Border Style="{StaticResource CardBorder}" Grid.Column="0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="NIC 1 - Primaerer Adapter" Style="{StaticResource SectionTitle}" />
                        <TextBlock
                            Text="{Binding SelectedAdapterPrimary}"
                            FontSize="14"
                            Foreground="{ThemeResource AppTextColor}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Sekundaerer Adapter Text -->
                <Border Style="{StaticResource CardBorder}" Grid.Column="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="NIC 2 - Sekundaerer Adapter" Style="{StaticResource SectionTitle}" />
                        <TextBlock
                            Text="{Binding SelectedAdapterSecondary}"
                            FontSize="14"
                            Foreground="{ThemeResource AppTextColor}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Informationen nebeneinander -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <!-- Informationen Primaerer Adapter -->
                <Border Style="{StaticResource CardBorder}" Grid.Column="0" Visibility="{Binding IsPrimaryAdapterSelected}">
                    <StackPanel Spacing="16">
                        <!-- Titel -->
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Netzwerkkarte:" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="{Binding SelectedAdapterPrimary}" Style="{StaticResource SectionTitle}" />
                        </StackPanel>

                        <!-- Name -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterName}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- MAC -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="MAC:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterMac}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- IPv4 Informationen Header -->
                        <TextBlock Text="IPv4 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0" />

                        <!-- IPv4 -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IPv4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <ItemsRepeater ItemsSource="{Binding PrimaryAdapterIpV4List}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>

                        <!-- Gateway -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterGateway}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- DNS4 -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <ItemsRepeater ItemsSource="{Binding PrimaryAdapterDns4List}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>

                        <StackPanel Visibility="{Binding IsPrimaryIpv6Available, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <!-- IPv6 Informationen Header -->
                            <TextBlock Text="IPv6 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0" />

                            <!-- IPv6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="IPv6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <ItemsRepeater ItemsSource="{Binding PrimaryAdapterIpV6List}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Grid>

                            <!-- Gateway6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway6:" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrimaryAdapterGateway6}" TextWrapping="Wrap" />
                            </Grid>

                            <!-- DNS6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <ItemsRepeater ItemsSource="{Binding PrimaryAdapterDns6List}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Informationen Sekundaerer Adapter -->
                <Border Style="{StaticResource CardBorder}" Grid.Column="1" Visibility="{Binding IsSecondaryAdapterSelected}">
                    <StackPanel Spacing="16">
                        <!-- Titel -->
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Netzwerkkarte:" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="{Binding SelectedAdapterSecondary}" Style="{StaticResource SectionTitle}" />
                        </StackPanel>

                        <!-- Name -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterName}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- MAC -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="MAC:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterMac}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- IPv4 Informationen Header -->
                        <TextBlock Text="IPv4 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0" />

                        <!-- IPv4 -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IPv4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <ItemsRepeater ItemsSource="{Binding SecondaryAdapterIpV4List}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>

                        <!-- Gateway -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway:" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterGateway}" TextWrapping="Wrap" />
                        </Grid>

                        <!-- DNS4 -->
                        <Grid ColumnDefinitions="140,*" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS4:" FontWeight="SemiBold" VerticalAlignment="Top" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <ItemsRepeater ItemsSource="{Binding SecondaryAdapterDns4List}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </Grid>

                        <StackPanel Visibility="{Binding IsSecondaryIpv6Available, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <!-- IPv6 Informationen Header -->
                            <TextBlock Text="IPv6 Informationen:" FontWeight="Bold" FontSize="14" Margin="0,8,0,0" />

                            <!-- IPv6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="IPv6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <ItemsRepeater ItemsSource="{Binding SecondaryAdapterIpV6List}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Grid>

                            <!-- Gateway6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Gateway6:" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SecondaryAdapterGateway6}" TextWrapping="Wrap" />
                            </Grid>

                            <!-- DNS6 -->
                            <Grid ColumnDefinitions="140,*" RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="DNS6:" FontWeight="SemiBold" VerticalAlignment="Top" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <ItemsRepeater ItemsSource="{Binding SecondaryAdapterDns6List}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
